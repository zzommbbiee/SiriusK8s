[635.25147, "o", "итого 132\r\ndrwxr-xr-x. 2 root root   4096 апр  1 11:08 .\r\ndrwxr-xr-x. 3 root root   4096 апр  1 11:08 ..\r\n-rwxr-xr-x. 1 root root     48 апр  1 11:08 mystery_bad_interpreter\r\n-rw-r--r--. 1 root root 111440 апр  1 11:08 mystery_no_exec\r\n-rwxr-xr-x. 1 root root    256 апр  1 11:08 mystery_truncated_elf\r\n-rwxr-xr-x. 1 root root     11 апр  1 11:08 not_a_binary\r\n"]
[635.25164, "o", "\r\nРазбирайте: file, chmod, ldd, strace -f ./имя , objdump/readelf (при необходимости apt install).\r\nУдаление каталога: rm -rf /opt/break_lab"]
