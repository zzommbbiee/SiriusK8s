[448.800421, "o", "\r\n\u001b[?2004l\r    1  \u001b[200~cd PRACTIC/BREAK/br\r\n    2  cd PRACTIC/BREAK/break_lab\r\n    3  cd BREAK/break_lab\r\n    4  sudo bash 01_nginx_log_challenge.sh\r\n    5  sudo nano 01_nginx_log_challenge.sh \r\n    6  sudo bash 01_nginx_log_challenge.sh\r\n    7  cd\r\n    8  c\r\n    9  cd BREAK/break_lab\r\n   10  ls\r\n   11  cd\r\n   12  ls\r\n   13  which access.log\r\n   14  sudo vim/var/log/nginx/access_json.log\r\n   15  sudo vim /var/log/nginx/access_json.log\r\n   16  sudo awk '{print $1}' /var/log/nginx/access_json.log | sort | uniq -c | sort -rn | head\r\n   17  sudo awk '{print $1}' /var/log/nginx/access_json.log | sort | uniq -c | sort -rn | head -n 10\r\n   18  sudo awk '{print $1}' /var/log/nginx/access.log | sort | uniq -c | sort -rn | head -n 10\r\n   19  sudo awk '{print $1}' /var/log/nginx/access.log | sort | uniq -c | sort -rn | tail -n 10\r\n   20  sudo awk '{print $1}' /var/log/nginx/access.log | sort | uniq -c | sort -rn | head -n 10\r\n   21  cd BREAK/break_lab\r\n   22  sudo bash 02_network_break.sh \r\n   23  cd\r\n   24  ip -br a\r\n"]
[448.800479, "o", "   25  sudo vim /etc/resolv.conf \r\n   26  sudo vim /etc/nsswitch.conf\r\n   27  curl www.avito.ru\r\n   28  sudo curl www.avito.ru\r\n   29  ping 8.8.8.8\r\n   30  ip -br a\r\n   31  sudo vim /etc/nsswitch.conf\r\n   32  sudo curl www.avito.ru\r\n   33  ping 8.8.8.8\r\n   34  sudo vim /etc/resolv.conf \r\n   35  sudo vim /etc/nsswitch.conf\r\n   36  nslookup www.avito.ru\r\n   37  sudo vim /etc/nsswitch.conf\r\n   38  sudo vim /etc/resolv.conf \r\n   39  nslookup www.avito.ru\r\n   40  nmcli device status\r\n   41  ip route show\r\n   42  sudo nmcli con mod \"enp1s0\" ipv4.addresses 192.168.122.10/24\r\n   43  sudo nmcli con mod \"enp1s0\" ipv4.gateway 192.168.122.1/24\r\n   44  curl www.avito.ru\r\n   45  sudo curl www.avito.ru\r\n   46  sudo bash 03_disk_break.sh \r\n   47  cd\r\n   48  du -h --max-depth=1 / 2>/dev/null | sort -hr\r\n   49  cd /var/\r\n   50  ls\r\n   51  du -h --max-depth=1 / 2>/dev/null | sort -hr\r\n   52  find / -xdev -type  f -size +100V 2>/dev/null\r\n   53  cd\r\n   54  find / -xdev -type  f -size +100V 2>/dev/null\r\n   55  cd /var/\r\n   56  cd"]
[448.800519, "o", " /var/lib/linux_break_lab\r\n   57  ls\r\n   58  kill $(cat /var/lib/linux_break_lab/orphan_holder.pid)\r\n   59  sudo kill $(cat /var/lib/linux_break_lab/orphan_holder.pid)\r\n   60  df -h\r\n   61  du\r\n   62  rm disk_fill.bin\r\n   63  sudo rm -rf disk_fill.bin\r\n   64  ls\r\n   65  du -h --max-depth=1 / 2>/dev/null | sort -hr\r\n   66  clear\r\n   67  sudo dnf install asciinema\r\n   68  asciinema auth\r\n   69  asciinema rec demo.cast\r\n   70  sudo asciinema rec demo.cast\r\n   71  asciinema rec demo.cast\r\n   72  asciinema rec demo1.cast\r\n   73  exit\r\n   74  awk '{print $1}' var/log/nginx/access.log | sort | uniq -c | sort -nr | head -10\r\n   75  ls /var/log/nginx/\r\n   76  awk '{print $1}' var/log/nginx/access_json.log | sort | uniq -c | sort -nr | head -10\r\n   77  awk '{print $1}' /var/log/nginx/access.log | sort | uniq -c | sort -nr | head -10\r\n   78  cd ~/BREAK/\r\n   79  ls\r\n   80  cd break_lab/\r\n   81  ls\r\n   82  sudo bash 02_network_break.sh \r\n   83  cd\r\n   84  ip -br a\r\n   85  sudo nano /etc/resolv.conf \r\n   86  sudo vim /etc/"]
[448.800556, "o", "resolv.conf \r\n   87  sudo vim /etc/nsswitch.conf\r\n   88  ping 8.8.8.8\r\n   89  sudo systemctl restart NetworkManager.service\r\n   90  ping 8.8.8.8\r\n   91  curl www.avito.ru\r\n   92  cd BREAK/break_lab/\r\n   93  ls\r\n   94  sudo bash 03_disk_break.sh \r\n   95  cd\r\n   96  history\r\n\u001b]0;user@localhost:~\u0007\u001b[?2004h[\u001b[1;32muser@localhost\u001b[m ~]\u001b[33;1m$ \u001b[m"]
