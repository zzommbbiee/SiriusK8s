[414.647273, "o", "\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n 03: Освободить диск (без перезагрузки)\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n"]
[414.653682, "o", "Создаю файл /var/lib/linux_break_lab/disk_fill.bin размером 6144 MiB …\r\n"]
[415.167494, "o", "\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\n Готово\r\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\r\nЗаполнитель:     /var/lib/linux_break_lab/disk_fill.bin\r\n"]
[415.169088, "o", "Фон (deleted):   PID 35818, имя процесса break_lab_orphan_holder\r\nПодсказки: du, df, lsof | grep deleted, kill, tune2fs -m (осторожно с reserve)\r\nУбить держатель: kill $(cat /var/lib/linux_break_lab/orphan_holder.pid)\r\n"]
