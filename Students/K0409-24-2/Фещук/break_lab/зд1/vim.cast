[5.374482, "o", "\u001b[24;39H          \u001b[1;27H\u001b[27m\u001b[23m\u001b[29m\u001b[m\u001b[H\u001b[2J\u001b[1;1H\u001b[93mclass\u001b[m \u001b[1m\u001b[96mTemperatureConverter\u001b[m:\r\n    \u001b[95m\"\"\"Class for storing and converting temperatures between Celsii\u001b[3;1Hus, Fahrenheit, and Kelvin.\"\"\"\u001b[m\u001b[5;5HABSOLUTE_ZERO_CELSIUS = -\u001b[95m273.15\u001b[m\u001b[7;5H\u001b[93mdef\u001b[m \u001b[1m\u001b[96m__init__\u001b[m(self, celsius):\u001b[8;9H\u001b[95m\"\"\"Initialize temperature in Celsius with absolute zero chh\u001b[9;1Heck.\"\"\"\u001b[m\u001b[10;9Hself._celsius = self._validate_temperature(celsius)\u001b[12;5H\u001b[93mdef\u001b[m \u001b[1m\u001b[96m_validate_temperature\u001b[m(self, celsius):\u001b[13;9H\u001b[95m\"\"\"Validate that temperature is not below absolute zero.\"\"\"\u001b[14;1H\"\u001b[m\u001b[15;9H\u001b[93mif\u001b[m celsius < self.ABSOLUTE_ZERO_CELSIUS:\u001b[16;13H\u001b[1m\u001b[96mprint\u001b[m(f\u001b[95m\"Warning: Temperature {celsius}°\u001b[16;52HC is below absoo\u001b[17;1Hlute zero. Setting to {self.ABSOLUTE_ZERO_CELSIUS}°\u001b[17;52HC.\"\u001b[m)\u001b[18;13H\u001b[93mreturn\u001b[m self.ABSOLUTE_ZERO_CELSIUS\u001b[19;9H\u001b[93mreturn\u001b[m celsius\u001b[21;5H\u001b[38;5;81m@\u001b[m\u001b[1m\u001b[96mproperty\u001b[m\r\n    \u001b[93mdef\u001b[m \u001b[1m\u001b[96mcelsius\u001b[m(self):\u001b[23;9H\u001b[95m\"\"\"Get temperature in Celsius.\"\"\"\u001b[m\u001b[24;49H1,27\u001b[7CН\u001b[24;61Hа\u001b[24;62Hч\u001b[24;63Hа\u001b[24;64Hл\u001b[24;65Hо\u001b[24;1H\"test1.py\" 132L, 4453B\u001b[1;27H\u001b[?25h"]
