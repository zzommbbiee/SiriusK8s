[40.458885, "o", "\u001b[24;39H \u001b[12;1H\u001b[1;1H        \u001b[93mreturn\u001b[m cls(celsius_value)\u001b[2;5H\u001b[K\u001b[3;1H    \u001b[38;5;81m@\u001b[m\u001b[1m\u001b[96mclassmethod\u001b[m\u001b[3;17H\u001b[K\u001b[4;5H\u001b[93mdef\u001b[m \u001b[1m\u001b[96mfrom_kelvin\u001b[m(cls, kelvin):\r\n        \u001b[95m\"\"\"Create a TemperatureConverter instance from Kelvin.\"\"\"\u001b[m\u001b[6;9Hcelsius_value = cls.kelvin_to_celsius(kelvin)\r\n        \u001b[93mreturn\u001b[m cls(celsius_value)\u001b[8;9H\u001b[K\u001b[9;1H    \u001b[93mdef\u001b[m \u001b[1m\u001b[96m__repr__\u001b[m(self):\u001b[10;9H\u001b[95m\"\"\"String representation of the temperature.\"\"\"\u001b[m\u001b[10;56H\u001b[K\u001b[11;9H\u001b[93mreturn\u001b[m f\u001b[95m\"TemperatureConverter({self._celsius}°\u001b[11;55HC)\"\u001b[m\u001b[12;5H\u001b[K\u001b[13;9H\u001b[K\u001b[14;1H\u001b[96m# Example usage and testing\u001b[m\r\n\u001b[93mif\u001b[m __name__ == \u001b[95m\"__main__\"\u001b[m:\u001b[15;27H\u001b[K\u001b[16;5H\u001b[96m# Test basic functionality\u001b[m\u001b[16;31H\u001b[K\u001b[17;1H    tc1 = TemperatureConverter(\u001b[95m0\u001b[m)  \u001b[96m# 0°\u001b[17;40HC\u001b[m\u001b[17;41H\u001b[K\u001b[18;5H\u001b[1m\u001b[96mprint\u001b[m(f\u001b[95m\"tc1: {tc1}\"\u001b[m)\u001b[18;25H\u001b[K\u001b[19;5H\u001b[1m\u001b[96mprint\u001b[m(f\u001b[95m\"Fahrenheit: {tc1.fahrenheit}\"\u001b[m)  \u001b[96m# 32.0\u001b[m\r\n    \u001b[1m\u001b[96mprint\u001b[m(f\u001b[95m\"Kelvin: {tc1.kelvin}\"\u001b[m)  \u001b[96m# 273.15\u001b[m\u001b[21;5H\u001b[K\u001b[22;5H\u001b[1m\u001b[96mprint\u001b[m(\u001b[95m\"\u001b[m\u001b[38;5;224m\\n\u001b[m\u001b[95m\"\u001b[m + \u001b[95m\"=\"\u001b[m*\u001b[95m40\u001b[m + \u001b[95m\"\u001b[m\u001b[38;5;224m\\n\u001b[m\u001b[95m\"\u001b[m)\u001b[23;9H\u001b[K\u001b[24;49H84,0-1       66 %\u001b[12;1H\u001b[?25h"]
[41.138, "o", "\u001b[?25l\u001b[24;39H}\u001b[12;1H"]
[41.142949, "o", "\u001b[24;39H \u001b[23;1H\u001b[1;9H\u001b[K\u001b[2;5Htc4.celsius = \u001b[95m100\u001b[m\r\n    \u001b[1m\u001b[96mprint\u001b[m(f\u001b[95m\"After setting celsius to 100: {tc4} -> Fahrenheit: {tcc\u001b[4;1H4.fahrenheit}\"\u001b[m)  \u001b[96m# 212.0\u001b[m\u001b[4;26H\u001b[K\u001b[5;9H\u001b[K\u001b[6;5Htc4.fahrenheit = \u001b[95m32\u001b[m\u001b[6;25H\u001b[K\u001b[7;5H\u001b[1m\u001b[96mprint\u001b[m(f\u001b[95m\"After setting fahrenheit to 32: {tc4} -> Celsius: {tc44\u001b[8;1H.celsius}\"\u001b[m)  \u001b[96m# 0.0\u001b[m\u001b[9;5H\u001b[K\u001b[10;5Htc4.kelvin = \u001b[95m0\u001b[m\u001b[10;19H\u001b[K\u001b[11;5H\u001b[1m\u001b[96mprint\u001b[m(f\u001b[95m\"After setting kelvin to 0: {tc4} -> Celsius: {tc4.celss\u001b[12;1Hius}\"\u001b[m)  \u001b[96m# -273.15\u001b[m\r\n\r\n    \u001b[1m\u001b[96mprint\u001b[m(\u001b[95m\"\u001b[m\u001b[38;5;224m\\n\u001b[m\u001b[95m\"\u001b[m + \u001b[95m\"=\"\u001b[m*\u001b[95m40\u001b[m + \u001b[95m\"\u001b[m\u001b[38;5;224m\\n\u001b[m\u001b[95m\"\u001b[m)\r\n    \u001b[15;5H\u001b[K\u001b[16;12H\u001b[96mabsolute zero boundary\u001b[m\u001b[17;7H5\u001b[24C-\u001b[95m300\u001b[m)  \u001b[96m# Below absolute zero\u001b[m\u001b[18;13H\u001b[95mAfter trying to set below absolute zero: {tc5}\"\u001b[m)  \u001b[96m# -22\u001b[19;1H73.15\u001b[m\u001b[19;6H\u001b[K\u001b[20;5H\u001b[K\u001b[21;5Htc5.celsius = -\u001b[95m500\u001b[m\u001b[22;11Hf\u001b[95m\"After trying to set celsius to -500: {tc5}\"\u001b[m)  \u001b[96m# -273.11\u001b[23;1H5\u001b[m\u001b[24;49H132,67  О\u001b[24;58Hк\u001b[24;59Hо\u001b[24;60Hн\u001b[24;61Hч\u001b[24;62Hа\u001b[24;63Hн\u001b[24;64Hи\u001b[24;65Hе\u001b[23;1H\u001b[?25h"]
