[5.353834, "o", "\u001b[1;1H\u001b[38;5;130mclass\u001b[m \u001b[36mTemperatureConverter\u001b[m:\r\n    \u001b[31m\"\"\"Class for storing and converting temperatures between Celsii\u001b[3;1Hus, Fahrenheit, and Kelvin.\"\"\"\u001b[m\u001b[3;31H\u001b[K\u001b[5;5HABSOLUTE_ZERO_CELSIUS = -\u001b[31m273.15\u001b[m\u001b[7;5H\u001b[38;5;130mdef\u001b[m \u001b[36m__init__\u001b[m(self, celsius):\u001b[8;9H\u001b[31m\"\"\"Initialize temperature in Celsius with absolute zero chh\u001b[9;1Heck.\"\"\"\u001b[m\u001b[10;9Hself._celsius = self._validate_temperature(celsius)\u001b[12;5H\u001b[38;5;130mdef\u001b[m \u001b[36m_validate_temperature\u001b[m(self, celsius):\u001b[13;9H\u001b[31m\"\"\"Validate that temperature is not below absolute zero.\"\"\"\u001b[14;1H\"\u001b[m\u001b[15;9H\u001b[38;5;130mif\u001b[m celsius < self.ABSOLUTE_ZERO_CELSIUS:\u001b[16;13H\u001b[36mprint\u001b[m(f\u001b[31m\"Warning: Temperature {celsius}°\u001b[16;52HC is below absoo\u001b[17;1Hlute zero. Setting to {self.ABSOLUTE_ZERO_CELSIUS}°\u001b[17;52HC.\"\u001b[m)\u001b[18;13H\u001b[38;5;130mreturn\u001b[m self.ABSOLUTE_ZERO_CELSIUS\u001b[19;9H\u001b[38;5;130mreturn\u001b[m celsius\u001b[21;5H\u001b[35m@\u001b[m\u001b[36mproperty\u001b[m\r\n    \u001b[38;5;130mdef\u001b[m \u001b[36mcelsius\u001b[m(self):\u001b[23;9H\u001b[31m\"\"\"Get temperature in Celsius.\"\"\"\u001b[m\u001b[24;49H1,27\u001b[7CН\u001b[24;61Hа\u001b[24;62Hч\u001b[24;63Hа\u001b[24;64Hл\u001b[24;65Hо\u001b[1;27H\u001b[?25h\u001b[?4m"]
