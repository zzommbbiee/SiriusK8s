[94.891859, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mshort-precise\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 254 (press h for help or q to quit)\u001b[27m\u001b[K"]
[94.892855, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is very similar, but shows classic syslog timestamps with full microsecond\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 255 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               precision.\u001b[m"]
[94.892956, "o", "\r\n"]
[94.892991, "o", "\u001b[7m Manual page journalctl(1) line 256 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.302092, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[95.302714, "o", "\r\n\u001b[7m Manual page journalctl(1) line 257 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mshort-monotonic\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 258 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is very similar, but shows monotonic timestamps instead of wallclock\u001b[m"]
[95.302791, "o", "\r\n\u001b[7m Manual page journalctl(1) line 259 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.312562, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[95.312915, "o", "               timestamps.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 260 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.313049, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 261 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mshort-delta\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 262 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.34483, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               as for \u001b[1mshort-monotonic \u001b[22mbut includes the time difference to the previous\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 263 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.345084, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               entry. Maybe unreliable time differences are marked by a \"*\".\u001b[m\r\n"]
[95.345167, "o", "\u001b[7m Manual page journalctl(1) line 264 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[95.345225, "o", "\u001b[m"]
[95.345348, "o", "\r\n\u001b[7m Manual page journalctl(1) line 265 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.372831, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[95.373079, "o", "           \u001b[1mshort-unix\u001b[0m\u001b[m"]
[95.373222, "o", "\r\n\u001b[7m Manual page journalctl(1) line 266 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is very similar, but shows seconds passed since January 1st 1970 UTC\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 267 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[95.373435, "o", "               instead of wallclock timestamps (\"UNIX time\"). The time is shown with\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 268 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.73548, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[95.735999, "o", "               microsecond accuracy.\u001b[m"]
[95.73611, "o", "\r\n"]
