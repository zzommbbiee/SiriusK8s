[50.620697, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           connect to.\u001b[m"]
[50.621898, "o", "\r\n\u001b[7m Manual page journalctl(1) line 68 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 69 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-m\u001b[22m, \u001b[1m--merge\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 70 (press h for help or q to quit)\u001b[27m\u001b[K"]
[51.342647, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show entries interleaved from all available journals, including remote ones.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 71 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n"]
[51.342716, "o", "\u001b[7m Manual page journalctl(1) line 72 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-D \u001b[4m\u001b[22mDIR\u001b[24m, \u001b[1m--directory=\u001b[4m\u001b[22mDIR\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 73 (press h for help or q to quit)\u001b[27m\u001b[K"]
[51.363385, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[51.363666, "o", "           Takes a directory path as argument. If specified, journalctl will operate on\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 74 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           the specified journal directory \u001b[4mDIR\u001b[24m instead of the default runtime and system\u001b[m"]
[51.364035, "o", "\r\n\u001b[7m Manual page journalctl(1) line 75 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           journal paths.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 76 (press h for help or q to quit)\u001b[27m\u001b[K"]
[51.384091, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[51.385068, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 77 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--file=\u001b[4m\u001b[22mGLOB\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 78 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Takes a file glob as an argument. If specified, journalctl will operate on the\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 79 (press h for help or q to quit)\u001b[27m\u001b[K"]
[52.113722, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           specified journal files matching \u001b[4mGLOB\u001b[24m instead of the default runtime and system\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 80 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           journal paths. May be specified multiple times, in which case files will be\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 81 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           suitably interleaved.\u001b[m"]
[52.113995, "o", "\r\n\u001b[7m Manual page journalctl(1) line 82 (press h for help or q to quit)\u001b[27m\u001b[K"]
[54.239918, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 83 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--root=\u001b[4m\u001b[22mROOT\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 84 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Takes a directory path as an argument. If specified, \u001b[1mjournalctl \u001b[22mwill operate on\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 85 (press h for help or q to quit)\u001b[27m\u001b[K"]
[54.318602, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           journal directories and catalog file hierarchy underneath the specified\u001b[m"]
[54.319398, "o", "\r\n\u001b[7m Manual page journalctl(1) line 86 (press h for help or q to quit)\u001b[27m\u001b[K"]
[54.321067, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           directory instead of the root directory (e.g.  \u001b[1m--update-catalog \u001b[22mwill create\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 87 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[4mROOT\u001b[24m/var/lib/systemd/catalog/database, and journal files under\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 88 (press h for help or q to quit)\u001b[27m\u001b[K"]
[55.202784, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[55.203584, "o", "           \u001b[4mROOT\u001b[24m/run/journal/ or \u001b[4mROOT\u001b[24m/var/log/journal/ will be displayed).\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 89 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[55.205302, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 90 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--image=\u001b[4m\u001b[22mIMAGE\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 91 (press h for help or q to quit)\u001b[27m\u001b[K"]
[55.279606, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Takes a path to a disk image file or block device node. If specified,\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 92 (press h for help or q to quit)\u001b[27m\u001b[K"]
[55.28032, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mjournalctl \u001b[22mwill operate on the file system in the indicated disk image. This\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 93 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           option is similar to \u001b[1m--root=\u001b[22m, but operates on file systems stored in disk\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 94 (press h for help or q to quit)\u001b[27m\u001b[K"]
[55.969668, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           images or block devices, thus providing an easy way to extract log data from\u001b[m"]
[55.971317, "o", "\r\n"]
[55.971392, "o", "\u001b[7m Manual page journalctl(1) line 95 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           disk images. The disk image should either contain just a file system or a set\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 96 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           of file systems within a GPT partition table, following the \u001b[34m\u001b[1mDiscoverable\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 97 (press h for help or q to quit)\u001b[27m\u001b[K"]
[56.044984, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[56.045014, "o", "           \u001b[1m\u001b[34mPartitions Specification\u001b[0m\u001b[1m\u001b[22m[1]. For further information on supported disk images,\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 98 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[56.045154, "o", "           see \u001b[1msystemd-nspawn\u001b[22m(1)'s switch of the same name.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 99 (press h for help or q to quit)\u001b[27m\u001b[K"]
[56.04517, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[56.045388, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 100 (press h for help or q to quit)\u001b[27m\u001b[K"]
[56.593937, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--namespace=\u001b[4m\u001b[22mNAMESPACE\u001b[0m\u001b[m"]
[56.594672, "o", "\r\n\u001b[7m Manual page journalctl(1) line 101 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[56.595037, "o", "           Takes a journal namespace identifier string as argument. If not specified the\u001b[m\r\n"]
[56.59634, "o", "\u001b[7m Manual page journalctl(1) line 102 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[56.596386, "o", "           data collected by the default namespace is shown. If specified shows the log\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 103 (press h for help or q to quit)\u001b[27m\u001b[K"]
[56.640402, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[56.640507, "o", "           data of the specified namespace instead. If the namespace is specified as \"*\"\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 104 (press h for help or q to quit)\u001b[27m\u001b[K"]
[56.640553, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[56.640562, "o", "           data from all namespaces is shown, interleaved. If the namespace identifier is\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 105 (press h for help or q to quit)\u001b[27m\u001b[K"]
[56.64057, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[56.640835, "o", "           prefixed with \"+\" data from the specified namespace and the default namespace\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 106 (press h for help or q to quit)\u001b[27m\u001b[K"]
[57.258151, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           is shown, interleaved, but no other. For details about journal namespaces see\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 107 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1msystemd-journald.service\u001b[22m(8).\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 108 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[57.25878, "o", "\r\n\u001b[7m Manual page journalctl(1) line 109 (press h for help or q to quit)\u001b[27m\u001b[K"]
[57.290925, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mFILTERING OPTIONS\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 110 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       The following options control how to filter journal records:\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 111 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[57.291317, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 112 (press h for help or q to quit)\u001b[27m\u001b[K"]
[57.337635, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[57.338725, "o", "       \u001b[1m-S\u001b[22m, \u001b[1m--since=\u001b[22m, \u001b[1m-U\u001b[22m, \u001b[1m--until=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 113 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Start showing entries on or newer than the specified date, or on or older than\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 114 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           the specified date, respectively. Date specifications should be of the format\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 115 (press h for help or q to quit)\u001b[27m\u001b[K"]
[58.639585, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"2012-10-30 18:17:16\". If the time part is omitted, \"00:00:00\" is assumed. If\u001b[m"]
[58.640473, "o", "\r\n\u001b[7m Manual page journalctl(1) line 116 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           only the seconds component is omitted, \":00\" is assumed. If the date component\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 117 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           is omitted, the current day is assumed. Alternatively the strings \"yesterday\",\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 118 (press h for help or q to quit)\u001b[27m\u001b[K"]
[58.739888, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[58.740767, "o", "           \"today\", \"tomorrow\" are understood, which refer to 00:00:00 of the day before\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 119 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           the current day, the current day, or the day after the current day,\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 120 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           respectively.  \"now\" refers to the current time. Finally, relative times may be\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 121 (press h for help or q to quit)\u001b[27m\u001b[K"]
[59.575051, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[59.575113, "o", "           specified, prefixed with \"-\" or \"+\", referring to times before or after the\u001b[m\r\n"]
[59.575653, "o", "\u001b[7m Manual page journalctl(1) line 122 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[59.575871, "o", "           current time, respectively. For complete time and date specification, see\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 123 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[59.576217, "o", "           \u001b[1msystemd.time\u001b[22m(7). Note that \u001b[1m--output=short-full \u001b[22mprints timestamps that follow\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 124 (press h for help or q to quit)\u001b[27m\u001b[K"]
[60.880067, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           precisely this format.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 125 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 126 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-c\u001b[22m, \u001b[1m--cursor=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 127 (press h for help or q to quit)\u001b[27m\u001b[K"]
[62.286494, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Start showing entries from the location in the journal specified by the passed\u001b[m"]
[62.286796, "o", "\r\n\u001b[7m Manual page journalctl(1) line 128 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           cursor.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 129 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[62.286827, "o", "\u001b[m"]
[62.287281, "o", "\r\n\u001b[7m Manual page journalctl(1) line 130 (press h for help or q to quit)\u001b[27m\u001b[K"]
[76.692673, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--after-cursor=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 131 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Start showing entries from the location in the journal \u001b[4mafter\u001b[24m the location\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 132 (press h for help or q to quit)\u001b[27m\u001b[K"]
[76.693321, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[76.693376, "o", "           specified by the passed cursor. The cursor is shown when the \u001b[1m--show-cursor\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 133 (press h for help or q to quit)\u001b[27m\u001b[K"]
[76.738868, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[76.73939, "o", "           option is used.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 134 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 135 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[76.739433, "o", "       \u001b[1m--cursor-file=\u001b[4m\u001b[22mFILE\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 136 (press h for help or q to quit)\u001b[27m\u001b[K"]
[77.532433, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[77.533088, "o", "           If \u001b[4mFILE\u001b[24m exists and contains a cursor, start showing entries \u001b[4mafter\u001b[24m this\u001b[m"]
[77.534429, "o", "\r\n\u001b[7m Manual page journalctl(1) line 137 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           location. Otherwise show entries according to the other given options. At the\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 138 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           end, write the cursor of the last entry to \u001b[4mFILE\u001b[24m. Use this option to continually\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 139 (press h for help or q to quit)\u001b[27m\u001b[K"]
[77.586565, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[77.587715, "o", "           read the journal by sequentially calling \u001b[1mjournalctl\u001b[22m.\u001b[m"]
[77.588155, "o", "\r\n\u001b[7m Manual page journalctl(1) line 140 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 141 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-b [[\u001b[4m\u001b[22mID\u001b[24m][\u001b[4m±offset\u001b[24m]|\u001b[1mall\u001b[22m], \u001b[1m--boot[=[\u001b[4m\u001b[22mID\u001b[24m][\u001b[4m±offset\u001b[24m]|\u001b[1mall\u001b[22m]\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 142 (press h for help or q to quit)\u001b[27m\u001b[K"]
[77.745278, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[77.745567, "o", "           Show messages from a specific boot. This will add a match for \"_BOOT_ID=\".\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 143 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[77.745915, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 144 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The argument may be empty, in which case logs for the current boot will be\u001b[m"]
[77.745965, "o", "\r\n\u001b[7m Manual page journalctl(1) line 145 (press h for help or q to quit)\u001b[27m\u001b[K"]
[79.920076, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           shown.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 146 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 147 (press h for help or q to quit)\u001b[27m\u001b[K"]
[79.920372, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If the boot ID is omitted, a positive \u001b[4moffset\u001b[24m will look up the boots starting\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 148 (press h for help or q to quit)\u001b[27m\u001b[K"]
[80.608428, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           from the beginning of the journal, and an equal-or-less-than zero \u001b[4moffset\u001b[24m will\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 149 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           look up boots starting from the end of the journal. Thus, \u001b[1m1 \u001b[22mmeans the first\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 150 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           boot found in the journal in chronological order, \u001b[1m2 \u001b[22mthe second and so on; while\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 151 (press h for help or q to quit)\u001b[27m\u001b[K"]
[81.994472, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1m-0 \u001b[22mis the last boot, \u001b[1m-1 \u001b[22mthe boot before last, and so on. An empty \u001b[4moffset\u001b[24m is\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 152 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           equivalent to specifying \u001b[1m-0\u001b[22m, except when the current boot is not the last boot\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 153 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           (e.g. because \u001b[1m--directory \u001b[22mwas specified to look at logs from a different\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 154 (press h for help or q to quit)\u001b[27m\u001b[K"]
[82.026406, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[82.026867, "o", "           machine).\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 155 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 156 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If the 32-character \u001b[4mID\u001b[24m is specified, it may optionally be followed by \u001b[4moffset\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 157 (press h for help or q to quit)\u001b[27m\u001b[K"]
[82.54191, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           which identifies the boot relative to the one given by boot \u001b[4mID\u001b[24m. Negative values\u001b[m"]
[82.542116, "o", "\r\n\u001b[7m Manual page journalctl(1) line 158 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           mean earlier boots and positive values mean later boots. If \u001b[4moffset\u001b[24m is not\u001b[m"]
[82.542494, "o", "\r\n\u001b[7m Manual page journalctl(1) line 159 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           specified, a value of zero is assumed, and the logs for the boot given by \u001b[4mID\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 160 (press h for help or q to quit)\u001b[27m\u001b[K"]
[82.570725, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           are shown.\u001b[m"]
[82.570993, "o", "\r\n\u001b[7m Manual page journalctl(1) line 161 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n"]
[82.571045, "o", "\u001b[7m Manual page journalctl(1) line 162 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The special argument \u001b[1mall \u001b[22mcan be used to negate the effect of an earlier use of\u001b[m"]
[82.571114, "o", "\r\n\u001b[7m Manual page journalctl(1) line 163 (press h for help or q to quit)\u001b[27m\u001b[K"]
[82.598935, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[82.599338, "o", "           \u001b[1m-b\u001b[22m.\u001b[m"]
[82.599509, "o", "\r\n\u001b[7m Manual page journalctl(1) line 164 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 165 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-u\u001b[22m, \u001b[1m--unit=\u001b[4m\u001b[22mUNIT\u001b[24m\u001b[1m|\u001b[4m\u001b[22mPATTERN\u001b[0m\u001b[m\r\n"]
[82.599684, "o", "\u001b[7m Manual page journalctl(1) line 166 (press h for help or q to quit)\u001b[27m\u001b[K"]
[82.642383, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show messages for the specified systemd unit \u001b[4mUNIT\u001b[24m (such as a service unit), or\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 167 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           for any of the units matched by \u001b[4mPATTERN\u001b[24m. If a pattern is specified, a list of\u001b[m"]
[82.642621, "o", "\r\n"]
[82.642662, "o", "\u001b[7m Manual page journalctl(1) line 168 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           unit names found in the journal is compared with the specified pattern and all\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 169 (press h for help or q to quit)\u001b[27m\u001b[K"]
[83.101572, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[83.102291, "o", "           that match are used. For each unit name, a match is added for messages from the\u001b[m"]
[83.1024, "o", "\r\n\u001b[7m Manual page journalctl(1) line 170 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[83.103486, "o", "           unit (\"_SYSTEMD_UNIT=\u001b[4mUNIT\u001b[24m\"), along with additional matches for messages from\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 171 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           systemd and messages about coredumps for the specified unit. A match is also\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 172 (press h for help or q to quit)\u001b[27m\u001b[K"]
[83.132772, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           added for \"_SYSTEMD_SLICE=\u001b[4mUNIT\u001b[24m\", such that if the provided \u001b[4mUNIT\u001b[24m is a\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 173 (press h for help or q to quit)\u001b[27m\u001b[K"]
[83.133997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1msystemd.slice\u001b[22m(5) unit, all logs of children of the slice will be shown.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 174 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 175 (press h for help or q to quit)\u001b[27m\u001b[K"]
[83.2451, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           With \u001b[1m--user\u001b[22m, all \u001b[1m--unit \u001b[22marguments will be converted to match user messages as\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 176 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           if specified with \u001b[1m--user-unit\u001b[22m.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 177 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 178 (press h for help or q to quit)\u001b[27m\u001b[K"]
[87.841158, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This parameter can be specified multiple times.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 179 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 180 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--user-unit=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 181 (press h for help or q to quit)\u001b[27m\u001b[K"]
[87.913183, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[87.913755, "o", "           Show messages for the specified user session unit. This will add a match for\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 182 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[87.916153, "o", "           messages from the unit (\"_SYSTEMD_USER_UNIT=\" and \"_UID=\") and additional\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 183 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[87.91624, "o", "           matches for messages from session systemd and messages about coredumps for the\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 184 (press h for help or q to quit)\u001b[27m\u001b[K"]
[88.663677, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           specified unit. A match is also added for \"_SYSTEMD_USER_SLICE=\u001b[4mUNIT\u001b[24m\", such that\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 185 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           if the provided \u001b[4mUNIT\u001b[24m is a \u001b[1msystemd.slice\u001b[22m(5) unit, all logs of children of the\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 186 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           unit will be shown.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 187 (press h for help or q to quit)\u001b[27m\u001b[K"]
[88.713905, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[88.713968, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 188 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[88.713993, "o", "           This parameter can be specified multiple times.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 189 (press h for help or q to quit)\u001b[27m\u001b[K"]
[88.714015, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[88.714263, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 190 (press h for help or q to quit)\u001b[27m\u001b[K"]
[88.769859, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-t\u001b[22m, \u001b[1m--identifier=\u001b[4m\u001b[22mSYSLOG_IDENTIFIER\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 191 (press h for help or q to quit)\u001b[27m\u001b[K"]
[88.770125, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show messages for the specified syslog identifier \u001b[4mSYSLOG_IDENTIFIER\u001b[24m.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 192 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[88.770192, "o", "\u001b[m\r\n"]
[88.77082, "o", "\u001b[7m Manual page journalctl(1) line 193 (press h for help or q to quit)\u001b[27m\u001b[K"]
[89.519775, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[89.520368, "o", "           This parameter can be specified multiple times.\u001b[m"]
[89.52045, "o", "\r\n\u001b[7m Manual page journalctl(1) line 194 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 195 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-p\u001b[22m, \u001b[1m--priority=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 196 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.122406, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Filter output by message priorities or priority ranges. Takes either a single\u001b[m"]
[90.122679, "o", "\r\n\u001b[7m Manual page journalctl(1) line 197 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.122744, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           numeric or textual log level (i.e. between 0/\"emerg\" and 7/\"debug\"), or a range\u001b[m"]
[90.122859, "o", "\r\n\u001b[7m Manual page journalctl(1) line 198 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[90.122934, "o", "           of numeric/text log levels in the form FROM..TO. The log levels are the usual\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 199 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.142903, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           syslog log levels as documented in \u001b[1msyslog\u001b[22m(3), i.e.  \"emerg\" (0), \"alert\" (1),\u001b[m"]
[90.143258, "o", "\r\n\u001b[7m Manual page journalctl(1) line 200 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.143649, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"crit\" (2), \"err\" (3), \"warning\" (4), \"notice\" (5), \"info\" (6), \"debug\" (7). If\u001b[m"]
[90.143819, "o", "\r\n"]
[90.143846, "o", "\u001b[7m Manual page journalctl(1) line 201 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.144174, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[90.144311, "o", "           a single log level is specified, all messages with this log level or a lower\u001b[m"]
[90.144444, "o", "\r\n\u001b[7m Manual page journalctl(1) line 202 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.202796, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[90.202938, "o", "           (hence more important) log level are shown. If a range is specified, all\u001b[m"]
[90.203545, "o", "\r\n\u001b[7m Manual page journalctl(1) line 203 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.204328, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[90.204396, "o", "           messages within the range are shown, including both the start and the end value\u001b[m"]
[90.204617, "o", "\r\n"]
[90.20466, "o", "\u001b[7m Manual page journalctl(1) line 204 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.204724, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[90.204799, "o", "           of the range. This will add \"PRIORITY=\" matches for the specified priorities.\u001b[m"]
[90.204831, "o", "\r\n"]
[90.204863, "o", "\u001b[7m Manual page journalctl(1) line 205 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.909861, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[90.910048, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 206 (press h for help or q to quit)\u001b[27m\u001b[K"]
[90.911886, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--facility=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 207 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Filter output by syslog facility. Takes a comma-separated list of numbers or\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 208 (press h for help or q to quit)\u001b[27m\u001b[K"]
[91.852105, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           facility names. The names are the usual syslog facilities as documented in\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 209 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1msyslog\u001b[22m(3).  \u001b[1m--facility=help \u001b[22mmay be used to display a list of known facility\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 210 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           names and exit.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 211 (press h for help or q to quit)\u001b[27m\u001b[K"]
[91.862582, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[91.862748, "o", "\u001b[m"]
[91.862817, "o", "\r\n\u001b[7m Manual page journalctl(1) line 212 (press h for help or q to quit)\u001b[27m\u001b[K"]
[91.863754, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-g\u001b[22m, \u001b[1m--grep=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 213 (press h for help or q to quit)\u001b[27m\u001b[K"]
[91.864478, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Filter output to entries where the \u001b[4mMESSAGE=\u001b[24m field matches the specified regular\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 214 (press h for help or q to quit)\u001b[27m\u001b[K"]
[91.894668, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[91.895356, "o", "           expression. PERL-compatible regular expressions are used, see \u001b[1mpcre2pattern\u001b[22m(3)\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 215 (press h for help or q to quit)\u001b[27m\u001b[K"]
[91.895483, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           for a detailed description of the syntax.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 216 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[91.895546, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 217 (press h for help or q to quit)\u001b[27m\u001b[K"]
[92.490104, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If the pattern is all lowercase, matching is case insensitive. Otherwise,\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 218 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           matching is case sensitive. This can be overridden with the \u001b[1m--case-sensitive\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 219 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           option, see below.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 220 (press h for help or q to quit)\u001b[27m\u001b[K"]
[92.509949, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 221 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           When used with \u001b[1m--lines=\u001b[22m, \u001b[1m--reverse \u001b[22mis implied.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 222 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 223 (press h for help or q to quit)\u001b[27m\u001b[K"]
[93.063553, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[93.064257, "o", "       \u001b[1m--case-sensitive[=BOOLEAN]\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 224 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Make pattern matching case sensitive or case insensitive.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 225 (press h for help or q to quit)\u001b[27m\u001b[K"]
[93.064554, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 226 (press h for help or q to quit)\u001b[27m\u001b[K"]
[93.084006, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[93.084951, "o", "       \u001b[1m-k\u001b[22m, \u001b[1m--dmesg\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 227 (press h for help or q to quit)\u001b[27m\u001b[K"]
[93.08524, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show only kernel messages. This implies \u001b[1m-b \u001b[22mand adds the match\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 228 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"_TRANSPORT=kernel\".\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 229 (press h for help or q to quit)\u001b[27m\u001b[K"]
[93.120092, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[93.120822, "o", "\u001b[m"]
[93.120959, "o", "\r\n\u001b[7m Manual page journalctl(1) line 230 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[93.121087, "o", "\u001b[1mOUTPUT OPTIONS\u001b[0m\u001b[m\r\n"]
[93.121208, "o", "\u001b[7m Manual page journalctl(1) line 231 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[93.121293, "o", "       The following options control how journal records are printed:\u001b[m"]
[93.121317, "o", "\r\n\u001b[7m Manual page journalctl(1) line 232 (press h for help or q to quit)\u001b[27m\u001b[K"]
[93.157163, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[93.15753, "o", "\r\n\u001b[7m Manual page journalctl(1) line 233 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-o\u001b[22m, \u001b[1m--output=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 234 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Controls the formatting of the journal entries that are shown. Takes one of the\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 235 (press h for help or q to quit)\u001b[27m\u001b[K"]
[93.60339, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           following options:\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 236 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 237 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mshort\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 238 (press h for help or q to quit)\u001b[27m\u001b[K"]
[94.253767, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is the default and generates an output that is mostly identical to the\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 239 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               formatting of classic syslog files, showing one line per journal entry.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 240 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 241 (press h for help or q to quit)\u001b[27m\u001b[K"]
[94.295812, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[94.296172, "o", "           \u001b[1mshort-full\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 242 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is very similar, but shows timestamps in the format the \u001b[1m--since= \u001b[22mand\u001b[m"]
[94.296655, "o", "\r\n\u001b[7m Manual page journalctl(1) line 243 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[1m--until= \u001b[22moptions accept. Unlike the timestamp information shown in \u001b[1mshort\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 244 (press h for help or q to quit)\u001b[27m\u001b[K"]
[94.340317, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               output mode this mode includes weekday, year and timezone information in\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 245 (press h for help or q to quit)\u001b[27m\u001b[K"]
[94.342308, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               the output, and is locale-independent.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 246 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[94.3424, "o", "\r\n\u001b[7m Manual page journalctl(1) line 247 (press h for help or q to quit)\u001b[27m\u001b[K"]
[94.841667, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[94.841879, "o", "           \u001b[1mshort-iso\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 248 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is very similar, but shows ISO 8601 wallclock timestamps.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 249 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
