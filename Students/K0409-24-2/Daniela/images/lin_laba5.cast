[96.8577, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               formats entries as JSON data structures, but prefixes them with an ASCII\u001b[m"]
[96.858328, "o", "\r\n\u001b[7m Manual page journalctl(1) line 309 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Record Separator character (0x1E) and suffixes them with an ASCII Line Feed\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 310 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.002202, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               character (0x0A), in accordance with \u001b[34m\u001b[1mJavaScript Object Notation (JSON) Text\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 311 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[1m\u001b[34mSequences\u001b[0m\u001b[1m\u001b[22m[5] (\"application/json-seq\").\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 312 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 313 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.032898, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mcat\u001b[0m\u001b[m"]
[97.033304, "o", "\r\n\u001b[7m Manual page journalctl(1) line 314 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               generates a very terse output, only showing the actual message of each\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 315 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               journal entry with no metadata, not even a timestamp. If combined with the\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 316 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.152355, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[1m--output-fields= \u001b[22moption will output the listed fields for each log record,\u001b[m"]
[97.15378, "o", "\r\n\u001b[7m Manual page journalctl(1) line 317 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               instead of the message.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 318 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 319 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.270452, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mwith-unit\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 320 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.270954, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               similar to \u001b[1mshort-full\u001b[22m, but prefixes the unit and user unit names instead of\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 321 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.271279, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               the traditional syslog identifier. Useful when using templated instances,\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 322 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.353945, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               as it will include the arguments in the unit names.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 323 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 324 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--output-fields=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 325 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.487692, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[97.48782, "o", "           A comma separated list of the fields which should be included in the output.\u001b[m"]
[97.488225, "o", "\r\n"]
[97.488282, "o", "\u001b[7m Manual page journalctl(1) line 326 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.488415, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This has an effect only for the output modes which would normally show all\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 327 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.488531, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[97.488578, "o", "           fields (\u001b[1mverbose\u001b[22m, \u001b[1mexport\u001b[22m, \u001b[1mjson\u001b[22m, \u001b[1mjson-pretty\u001b[22m, \u001b[1mjson-sse \u001b[22mand \u001b[1mjson-seq\u001b[22m), as well as\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 328 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.52595, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           on \u001b[1mcat\u001b[22m. For the former, the \"__CURSOR\", \"__REALTIME_TIMESTAMP\",\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 329 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.526051, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[97.526212, "o", "           \"__MONOTONIC_TIMESTAMP\", and \"_BOOT_ID\" fields are always printed.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 330 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 331 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.725212, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[97.725928, "o", "       \u001b[1m-n\u001b[22m, \u001b[1m--lines=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 332 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.726094, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[97.726201, "o", "           Show the most recent journal events and limit the number of events shown. If\u001b[m"]
[97.726228, "o", "\r\n"]
[97.726315, "o", "\u001b[7m Manual page journalctl(1) line 333 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.726355, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[97.726443, "o", "           \u001b[1m--follow \u001b[22mis used, this option is implied. The argument is a positive integer or\u001b[m"]
[97.726499, "o", "\r\n"]
[97.726552, "o", "\u001b[7m Manual page journalctl(1) line 334 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.75696, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"all\" to disable line limiting. The default value is 10 if no argument is\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 335 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           given.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 336 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 337 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.791708, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           When used with \u001b[1m--grep=\u001b[22m, \u001b[1m--reverse \u001b[22mis implied.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 338 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 339 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-r\u001b[22m, \u001b[1m--reverse\u001b[0m\u001b[m"]
[97.791799, "o", "\r\n\u001b[7m Manual page journalctl(1) line 340 (press h for help or q to quit)\u001b[27m\u001b[K"]
[97.979474, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Reverse output so that the newest entries are displayed first.\u001b[m"]
