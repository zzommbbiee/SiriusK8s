[99.853279, "o", "       \u001b[1m-x\u001b[22m, \u001b[1m--catalog\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 353 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Augment log lines with explanation texts from the message catalog. This will\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 354 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           add explanatory help texts to log messages in the output where this is\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 355 (press h for help or q to quit)\u001b[27m\u001b[K"]
[99.88547, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[99.885917, "o", "           available. These short help texts will explain the context of an error or log\u001b[m"]
[99.886129, "o", "\r\n\u001b[7m Manual page journalctl(1) line 356 (press h for help or q to quit)\u001b[27m\u001b[K"]
[99.886376, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           event, possible solutions, as well as pointers to support forums, developer\u001b[m"]
[99.886477, "o", "\r\n\u001b[7m Manual page journalctl(1) line 357 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[99.886626, "o", "           documentation, and any other relevant manuals. Note that help texts are not\u001b[m"]
[99.886692, "o", "\r\n\u001b[7m Manual page journalctl(1) line 358 (press h for help or q to quit)\u001b[27m\u001b[K"]
[100.21191, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[100.212917, "o", "           available for all messages, but only for selected ones. For more information on\u001b[m"]
[100.21342, "o", "\r\n"]
