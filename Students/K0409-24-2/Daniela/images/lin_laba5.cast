[101.203982, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[101.204588, "o", "           show full fields, allowing them to wrap or be truncated by the pager, if one is\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 374 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           used.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 375 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[101.204642, "o", "\r\n\u001b[7m Manual page journalctl(1) line 376 (press h for help or q to quit)\u001b[27m\u001b[K"]
[101.233306, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[101.233424, "o", "           The old options \u001b[1m-l\u001b[22m/\u001b[1m--full \u001b[22mare not useful anymore, except to undo \u001b[1m--no-full\u001b[22m.\u001b[m\r\n"]
