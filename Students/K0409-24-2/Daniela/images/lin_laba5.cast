[102.233373, "o", "\r\n\u001b[7m Manual page journalctl(1) line 403 (press h for help or q to quit)\u001b[27m\u001b[K"]
[102.344938, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[102.345812, "o", "           Immediately jump to the end of the journal inside the implied pager tool. This\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 404 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           implies \u001b[1m-n1000 \u001b[22mto guarantee that the pager will not buffer logs of unbounded\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 405 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           size. This may be overridden with an explicit \u001b[1m-n \u001b[22mwith some other numeric value,\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 406 (press h for help or q to quit)\u001b[27m\u001b[K"]
[104.200808, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[104.201522, "o", "           while \u001b[1m-nall \u001b[22mwill disable this cap. Note that this option is only supported for\u001b[m"]
[104.201783, "o", "\r\n\u001b[7m Manual page journalctl(1) line 407 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[104.201962, "o", "           the \u001b[1mless\u001b[22m(1) pager.\u001b[m"]
[104.20242, "o", "\r\n\u001b[7m Manual page journalctl(1) line 408 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[104.20267, "o", "\u001b[m"]
[104.202698, "o", "\r\n\u001b[7m Manual page journalctl(1) line 409 (press h for help or q to quit)\u001b[27m\u001b[K"]
