[221.348867, "o", "\u001b[?2004h\u001b[?1049h\u001b[22;0;0t\u001b[1;24r\u001b(B\u001b[m\u001b[4l\u001b[?7h\u001b[39;49m\u001b[?1h\u001b=\u001b[?1h\u001b=\u001b[?25l\u001b[39;49m\u001b(B\u001b[m\u001b[H\u001b[2J\u001b[22;42H\u001b(B\u001b[0;7m[ Чтение… ]\u001b(B\u001b[m\u001b[22;36H\u001b(B\u001b[0;7m[ Прочитано 39 строк ]\u001b(B\u001b[m\u001b[H\u001b(B\u001b[0;7m  GNU nano 8.0                     /opt/setup_broken_service.sh                              \u001b[1;92H\u001b(B\u001b[m\r\u001b[23d\u001b(B\u001b[0;7m^G\u001b(B\u001b[m Справка     \u001b(B\u001b[0;7m^O\u001b(B\u001b[m Записать    \u001b(B\u001b[0;7m^F\u001b(B\u001b[m Поиск\u001b[46G\u001b(B\u001b[0;7m^K\u001b(B\u001b[m Вырезать    \u001b(B\u001b[0;7m^T\u001b(B\u001b[m Выполнить   \u001b(B\u001b[0;7m^C\u001b(B\u001b[m Позиция\r\u001b[24d\u001b(B\u001b[0;7m^X\u001b(B\u001b[m Выход\u001b[16G\u001b(B\u001b[0;7m^R\u001b(B\u001b[m ЧитФайл     \u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Замена\u001b[46G\u001b(B\u001b[0;7m^U\u001b(B\u001b[m Вставить    \u001b(B\u001b[0;7m^J\u001b(B\u001b[m Выровнять   \u001b(B\u001b[0;7m^/\u001b(B\u001b[m К строке"]
[221.349652, "o", "\r\u001b[2d\u001b[36m#!/usr/bin/env bash\r\u001b[3d\u001b(B\u001b[0;1m\u001b[34mset\u001b[39m\u001b(B\u001b[m -euo pipefail\r\u001b[5dLAB\u001b[32m=\u001b(B\u001b[0;1m\u001b[33m\"/opt/break_lab\"\r\u001b[6d\u001b[34mmkdir\u001b[35m -p\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$LAB\"\r\u001b[8d\u001b[34mcat\u001b[39m\u001b(B\u001b[m \u001b[32m>\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$LAB/script_server.sh\"\u001b[39m\u001b(B\u001b[m \u001b[32m<<\u001b(B\u001b[0;1m\u001b[33m'EOF'\r\u001b[9d\u001b(B\u001b[0m\u001b[36m#!/usr/bin/env bash\r\u001b[10d\u001b(B\u001b[0;1m\u001b[34mset\u001b[39m\u001b(B\u001b[m -euo pipefail\r\u001b[11d\u001b(B\u001b[0;1m\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"script-server: старт $(date -Is)\"\u001b[39m\u001b(B\u001b[m \u001b[32m>&\u001b[39m\u001b(B\u001b[m2\r\u001b[12d\u001b[32mexit\u001b[39m\u001b(B\u001b[m 1\r\u001b[13dEOF\r\u001b[14d"]
[221.350384, "o", "\u001b(B\u001b[0;1m\u001b[34mchmod\u001b[39m\u001b(B\u001b[m +x \u001b(B\u001b[0;1m\u001b[33m\"$LAB/script_server.sh\"\r\u001b[16d\u001b[39m\u001b(B\u001b[mUNIT\u001b[32m=\u001b(B\u001b[0;1m\u001b[33m\"/etc/systemd/system/script-server.service\"\r\u001b[17d\u001b[34mcat\u001b[39m\u001b(B\u001b[m \u001b[32m>\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$UNIT\"\u001b[39m\u001b(B\u001b[m \u001b[32m<<\u001b[39m\u001b(B\u001b[mEOF\r\u001b[18d\u001b[32m[\u001b[39m\u001b(B\u001b[mUnit\u001b[32m]\r\u001b[19d\u001b[39m\u001b(B\u001b[mDescription\u001b[32m=\u001b[39m\u001b(B\u001b[mBreak Lab Script Server\r\u001b[20dAfter\u001b[32m=\u001b[39m\u001b(B\u001b[mnetwork.target\r\u001b[2d"]
