[95.73636, "o", "\r\n\u001b[7m Manual page journalctl(1) line 270 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[95.736533, "o", "           \u001b[1mverbose\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 271 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.7551, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[95.755334, "o", "               shows the full-structured entry items with all fields.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 272 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 273 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mexport\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 274 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.770452, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               serializes the journal into a binary (but mostly text-based) stream\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 275 (press h for help or q to quit)\u001b[27m\u001b[K"]
[95.770807, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               suitable for backups and network transfer (see \u001b[34m\u001b[1mJournal Export Format\u001b[0m\u001b[1m\u001b[22m[2] for\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 276 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[95.770848, "o", "               more information). To import the binary stream back into native journald\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 277 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.031506, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               format use \u001b[1msystemd-journal-remote\u001b[22m(8).\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 278 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.032223, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 279 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mjson\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 280 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.042404, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               formats entries as JSON objects, separated by newline characters (see\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 281 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.043436, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[34m\u001b[1mJournal JSON Format\u001b[0m\u001b[1m\u001b[22m[3] for more information). Field values are generally\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 282 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               encoded as JSON strings, with three exceptions:\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 283 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.073459, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 284 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                1. Fields larger than 4096 bytes are encoded as \u001b[1mnull \u001b[22mvalues. (This may be\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 285 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   turned off by passing \u001b[1m--all\u001b[22m, but be aware that this may allocate overly\u001b[m"]
[96.07393, "o", "\r\n\u001b[7m Manual page journalctl(1) line 286 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.143176, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   long JSON objects.)\u001b[m"]
[96.143518, "o", "\r\n\u001b[7m Manual page journalctl(1) line 287 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[96.144008, "o", "\r\n\u001b[7m Manual page journalctl(1) line 288 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                2. Journal entries permit non-unique fields within the same log entry.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 289 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.286643, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[96.286868, "o", "                   JSON does not allow non-unique fields within objects. Due to this, if a\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 290 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   non-unique field is encountered a JSON array is used as field value,\u001b[m"]
[96.287256, "o", "\r\n\u001b[7m Manual page journalctl(1) line 291 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   listing all field values as elements.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 292 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.315974, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[96.316123, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 293 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[96.316412, "o", "                3. Fields containing non-printable or non-UTF8 bytes are encoded as arrays\u001b[m"]
[96.316463, "o", "\r\n\u001b[7m Manual page journalctl(1) line 294 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   containing the raw bytes individually formatted as unsigned numbers.\u001b[m"]
[96.316573, "o", "\r\n\u001b[7m Manual page journalctl(1) line 295 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.534249, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[96.534738, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 296 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Note that this encoding is reversible (with the exception of the size\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 297 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               limit).\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 298 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.5661, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 299 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mjson-pretty\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 300 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               formats entries as JSON data structures, but formats them in multiple lines\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 301 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.774962, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               in order to make them more readable by humans.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 302 (press h for help or q to quit)\u001b[27m\u001b[K"]
[96.775126, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
