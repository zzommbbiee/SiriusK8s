[101.268672, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show all fields in full, even if they include unprintable characters or are\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 380 (press h for help or q to quit)\u001b[27m\u001b[K"]
[101.26908, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           very long. By default, fields with unprintable characters are abbreviated as\u001b[m"]
