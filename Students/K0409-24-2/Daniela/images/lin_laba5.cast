[101.118799, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This switch has an effect only on the \u001b[1mshort \u001b[22mfamily of output modes (see above).\u001b[m"]
