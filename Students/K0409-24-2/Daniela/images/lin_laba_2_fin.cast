[138.359378, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--offline\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 99 (press h for help or q to quit)\u001b[27m\u001b[K"]
[138.361422, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Work without a daemon. Makes \u001b[1mconnection add \u001b[22mand \u001b[1mconnection modify \u001b[22mcommands\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 100 (press h for help or q to quit)\u001b[27m\u001b[K"]
[138.38768899999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           accept and produce connection data via standard input/output. Ordinarily,\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 101 (press h for help or q to quit)\u001b[27m\u001b[K"]
[138.38944199999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           nmcli would communicate with the NetworkManager service.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 102 (press h for help or q to quit)\u001b[27m\u001b[K"]
[138.38973699999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 103 (press h for help or q to quit)\u001b[27m\u001b[K"]
[138.402488, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The connection data format (keyfile) is described in \u001b[1mnm-settings-\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 104 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mkeyfile\u001b[22m(5) manual.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 105 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 106 (press h for help or q to quit)\u001b[27m\u001b[K"]
[138.454209, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[138.45452699999998, "o", "       \u001b[1m-v \u001b[22m| \u001b[1m--version\u001b[0m\u001b[m"]
[138.45482799999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 107 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show \u001b[1mnmcli \u001b[22mversion.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 108 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 109 (press h for help or q to quit)\u001b[27m\u001b[K"]
[139.54988199999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-w \u001b[22m| \u001b[1m--wait \u001b[4m\u001b[22mseconds\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 110 (press h for help or q to quit)\u001b[27m\u001b[K"]
[139.55061999999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option sets a timeout period for which \u001b[1mnmcli \u001b[22mwill wait for\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 111 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           NetworkManager to finish operations. It is especially useful for commands\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 112 (press h for help or q to quit)\u001b[27m\u001b[K"]
[139.57820699999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           that may take a longer time to complete, e.g. connection activation.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 113 (press h for help or q to quit)\u001b[27m\u001b[K"]
[139.57854199999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 114 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Specifying a value of 0 instructs \u001b[1mnmcli \u001b[22mnot to wait but to exit\u001b[m"]
[139.57858, "o", "\r\n"]
[139.578595, "o", "\u001b[7m Manual page nmcli(1) line 115 (press h for help or q to quit)\u001b[27m\u001b[K"]
[139.592112, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[139.593213, "o", "           immediately with a status of success. The default value depends on the\u001b[m"]
[139.59331599999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 116 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           executed command.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 117 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 118 (press h for help or q to quit)\u001b[27m\u001b[K"]
[139.62278699999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mGENERAL COMMANDS\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 119 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mnmcli general \u001b[22m{\u001b[1mstatus \u001b[22m| \u001b[1mhostname \u001b[22m| \u001b[1mpermissions \u001b[22m| \u001b[1mlogging \u001b[22m| \u001b[1mreload\u001b[22m}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 120 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                     [\u001b[4mARGUMENTS\u001b[24m...]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 121 (press h for help or q to quit)\u001b[27m\u001b[K"]
[139.67724699999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[139.678469, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 122 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       Use this command to show NetworkManager status and permissions. You can also\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 123 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       get and change system hostname, as well as NetworkManager logging level and\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 124 (press h for help or q to quit)\u001b[27m\u001b[K"]
[141.86235, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       domains.\u001b[m"]
