[174.08109699999994, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Switch between tabular and multiline output:\u001b[m"]
[174.08216099999999, "o", "\r\n\u001b[7m Manual page nmcli(1) line 68 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 69 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           tabular\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 70 (press h for help or q to quit)\u001b[27m\u001b[K"]
[175.14180199999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Output is a table where each line describes a single entry. Columns\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 71 (press h for help or q to quit)\u001b[27m\u001b[K"]
[175.14215399999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               define particular properties of the entry.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 72 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 73 (press h for help or q to quit)\u001b[27m\u001b[K"]
[175.17364499999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           multiline\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 74 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Each entry comprises multiple lines, each property on its own line.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 75 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               The values are prefixed with the property name.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 76 (press h for help or q to quit)\u001b[27m\u001b[K"]
