[157.628109, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Wi-Fi and WWAN state, modifying connections, etc.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 167 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           that NetworkManager provides, like enable and disable networking, changing\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 166 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.639879, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.639953, "o", "\u001b[H\u001bM           Show the permissions a caller has for various authenticated operations\u001b[m"]
[157.64011699999998, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 165 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mpermissions\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 164 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 163 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.656294, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.656497, "o", "\u001b[H\u001bM           reads the /etc/hostname file when it starts.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 162 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.656525, "o", "\u001b[H\u001bM           systemd-hostnamed service uses the term \"static\" hostname and it only\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 161 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           stored in /etc/hostname file in most distributions. For example,\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 160 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.67222799999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.672643, "o", "\u001b[H\u001bM           \"persistent\" or \"static\" by other programs or tools. The hostname is\u001b[m\r\n"]
[157.67267799999996, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 159 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Note that the term \"system\" hostname may also be referred to as\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 158 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 157 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.68633799999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           NetworkManager to be set as a new system hostname.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 156 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.68656499999997, "o", "\u001b[H\u001bM           configured hostname. When you pass a hostname, it will be handed over to\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 155 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Get and change system hostname. With no arguments, this prints currently\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 154 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.702604, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mhostname \u001b[22m[\u001b[4mhostname\u001b[24m]\u001b[m"]
