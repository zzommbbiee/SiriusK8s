[161.93735999999996, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 54 (press h for help or q to quit)\u001b[27m\u001b[K"]
[161.937387, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           completions for the last argument. This is useful to implement argument\u001b[m"]
[161.93744699999996, "o", "\r\n"]
[161.93750599999998, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 53 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
