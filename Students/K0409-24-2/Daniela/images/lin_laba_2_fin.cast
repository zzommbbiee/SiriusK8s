[145.148278, "o", "           \u001b[1mdns-full\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 171 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Restart the DNS plugin. This is for example useful when using dnsmasq\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 172 (press h for help or q to quit)\u001b[27m\u001b[K"]
[145.17130599999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               plugin, which uses additional configuration in\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 173 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               /etc/NetworkManager/dnsmasq.d. If you edit those files, you can\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 174 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               restart the DNS plugin. This action shortly interrupts name\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 175 (press h for help or q to quit)\u001b[27m\u001b[K"]
[145.18831799999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               resolution.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 176 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
