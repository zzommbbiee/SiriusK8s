[155.01429199999995, "o", "           \u001b[1mprofile\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 306 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               only shows static profile configuration.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 307 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.022675, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[155.022918, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 308 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mactive\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 309 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               only shows active connection data (when the profile is active).\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 310 (press h for help or q to quit)\u001b[27m\u001b[K"]
