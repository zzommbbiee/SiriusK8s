[161.93938299999996, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 52 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.45414599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m--complete-args\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 51 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.455629, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 50 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           variable.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 49 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.46445599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           with mode \"auto\". Explicitly enabling coloring overrides the environment\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 48 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.464723, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           CLICOLOR_FORCE is set (to any non-empty value), then coloring is enabled\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 47 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.465238, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           coloring is disabled with mode \"auto\". If the environment variable\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 46 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.48522199999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           If the environment variable NO_COLOR is set (to any non-empty value), then\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 45 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.486091, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[162.486195, "o", "\u001b[H\u001bM\u001b[m"]
[162.48656499999998, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 44 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           supported by \u001b[1mnmcli\u001b[22m.\u001b[m"]
[162.48701899999998, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 43 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.49802799999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mcolors.d\u001b[22m(5). Please refer to the COLORS section for a list of color names\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 42 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.49852299999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           The actual colors used are configured as described in \u001b[1mterminal-\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 41 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 40 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.505202, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           output is directed to a terminal. The default value is auto.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 39 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.50542099999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[162.50548599999996, "o", "\u001b[H\u001bM           enables colors, no disables them, auto only produces colors when standard\u001b[m"]
[162.505514, "o", "\r\n"]
[162.50554799999998, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 38 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.505632, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[162.50565, "o", "\u001b[H\u001bM           This option controls color output (using terminal escape sequences).  yes\u001b[m"]
[162.505678, "o", "\r\n"]
[162.505805, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 37 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.533231, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-c \u001b[22m| \u001b[1m--colors \u001b[22m{yes | no | auto}\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 36 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 35 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           for a password if it is required for connecting to a network.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.54625399999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[162.54672899999997, "o", "\u001b[H\u001bM           scripts. This option controls, for example, whether you will be prompted\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 33 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           arguments, so do not use this option for non-interactive purposes like\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           When using this option \u001b[1mnmcli \u001b[22mwill stop and ask for any missing required\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.57502899999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-a \u001b[22m| \u001b[1m--ask\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K"]
[162.577295, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.19257799999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           stopping network connections and viewing network status.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 27 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.192751, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           NetworkManager without a GUI, including creating, editing, starting and\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 26 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u2022   Servers, headless machines, and terminals: \u001b[1mnmcli \u001b[22mcan be used to control\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 25 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.20633899999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 24 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.20660399999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           events. See \u001b[1mNetworkManager\u001b[22m(8) for details about these dispatcher scripts.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 23 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           execute scripts, called \"dispatcher scripts\", in response to network\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.22355299999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           better suited for script processing. Note that NetworkManager can also\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 21 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.22414299999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           connections manually.  \u001b[1mnmcli \u001b[22msupports a terse output format which is\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 20 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.22470699999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u2022   Scripts: Utilize NetworkManager via \u001b[1mnmcli \u001b[22minstead of managing network\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 19 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.23481599999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[163.235456, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 18 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Typical uses include:\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 17 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m"]
[163.23607399999997, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 16 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.25512399999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       device status. See \u001b[1mnmcli-examples\u001b[22m(7) for ready to run nmcli examples.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 15 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.255292, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[163.255358, "o", "\u001b[H\u001bM       and deactivate network connections, as well as control and display network\u001b[m"]
[163.25538799999998, "o", "\r\n"]
[163.25541799999996, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 14 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.25546099999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[163.25584599999996, "o", "\u001b[H\u001bM       graphical clients.  \u001b[1mnmcli \u001b[22mis used to create, display, edit, delete, activate,\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 13 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.26327599999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[163.26361199999997, "o", "\u001b[H\u001bM       network status. It can be utilized as a replacement for \u001b[1mnm-applet \u001b[22mor other\u001b[m"]
[163.264383, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 12 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mnmcli \u001b[22mis a command-line tool for controlling NetworkManager and reporting\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 11 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
[163.27946599999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[163.27981899999997, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM             | \u001b[1magent \u001b[22m| \u001b[1mmonitor\u001b[22m} [\u001b[4mCOMMAND\u001b[24m] [\u001b[4mARGUMENTS\u001b[24m...]\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 8 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mnmcli \u001b[22m[\u001b[4mOPTIONS\u001b[24m...] {\u001b[1mhelp \u001b[22m| \u001b[1mgeneral \u001b[22m| \u001b[1mnetworking \u001b[22m| \u001b[1mradio \u001b[22m| \u001b[1mconnection \u001b[22m| \u001b[1mdevice\u001b[0m\u001b[m"]
