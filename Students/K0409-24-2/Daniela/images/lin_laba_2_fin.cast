[157.70329099999998, "o", "\u001b[H\u001bM\u001b[m"]
[157.703375, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 152 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           additional command is provided for \u001b[1mnmcli general\u001b[22m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 151 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.718349, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
