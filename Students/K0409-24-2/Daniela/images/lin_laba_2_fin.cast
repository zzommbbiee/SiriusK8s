[141.89401399999997, "o", "           Show overall status of NetworkManager. This is the default action, when no\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 128 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[141.89409799999999, "o", "           additional command is provided for \u001b[1mnmcli general\u001b[22m.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 129 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[141.894615, "o", "\r\n\u001b[7m Manual page nmcli(1) line 130 (press h for help or q to quit)\u001b[27m\u001b[K"]
[141.92565299999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mhostname \u001b[22m[\u001b[4mhostname\u001b[24m]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 131 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Get and change system hostname. With no arguments, this prints currently\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 132 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           configured hostname. When you pass a hostname, it will be handed over to\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 133 (press h for help or q to quit)\u001b[27m\u001b[K"]
[141.96357799999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[141.964291, "o", "           NetworkManager to be set as a new system hostname.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 134 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[141.96491799999995, "o", "\u001b[m"]
[141.965758, "o", "\r\n\u001b[7m Manual page nmcli(1) line 135 (press h for help or q to quit)\u001b[27m\u001b[K"]
[141.96601399999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Note that the term \"system\" hostname may also be referred to as\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 136 (press h for help or q to quit)\u001b[27m\u001b[K"]
[142.040142, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"persistent\" or \"static\" by other programs or tools. The hostname is\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 137 (press h for help or q to quit)\u001b[27m\u001b[K"]
[142.041447, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           stored in /etc/hostname file in most distributions. For example,\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 138 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           systemd-hostnamed service uses the term \"static\" hostname and it only\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 139 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.00939, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           reads the /etc/hostname file when it starts.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 140 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.01020599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.010922, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 141 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.010986, "o", "       \u001b[1mpermissions\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 142 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.08128999999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.08137999999997, "o", "           Show the permissions a caller has for various authenticated operations\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 143 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.081549, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.08164699999998, "o", "           that NetworkManager provides, like enable and disable networking, changing\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 144 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.08277099999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.08293699999996, "o", "           Wi-Fi and WWAN state, modifying connections, etc.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 145 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.15236799999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.15263399999998, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 146 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.152939, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.15677699999998, "o", "       \u001b[1mlogging \u001b[22m[\u001b[1mlevel \u001b[4m\u001b[22mlevel\u001b[24m] [\u001b[1mdomains \u001b[4m\u001b[22mdomains\u001b[24m...]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 147 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Get and change NetworkManager logging level and domains. Without any\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 148 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.52738599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           argument current logging level and domains are shown. In order to change\u001b[m"]
[144.52747699999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 149 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           logging state, provide \u001b[1mlevel \u001b[22mand, or, \u001b[1mdomain \u001b[22mparameters. See\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 150 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mNetworkManager.conf\u001b[22m(5) for available level and domain values.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 151 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.548093, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.548297, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 152 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[144.54834799999998, "o", "       \u001b[1mreload \u001b[22m[\u001b[4mflags\u001b[24m...]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 153 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Reload NetworkManager's configuration and perform certain updates, like\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 154 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.56958099999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           flushing caches or rewriting external state to disk. This is similar to\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 155 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           sending SIGHUP to NetworkManager but it allows for more fine-grained\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 156 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           control over what to reload through the flags argument. It also allows\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 157 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.590619, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           non-root access via PolicyKit and contrary to signals it is synchronous.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 158 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Available flags are:\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 159 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 160 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.613883, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mconf\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 161 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Reload the NetworkManager.conf configuration from disk. Note that this\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 162 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               does not include connections, which can be reloaded through \u001b[1mnmcli\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 163 (press h for help or q to quit)\u001b[27m\u001b[K"]
[144.640516, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[1mconnection reload \u001b[22minstead.\u001b[m"]
[144.640878, "o", "\r\n\u001b[7m Manual page nmcli(1) line 164 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 165 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mdns-rc\u001b[0m\u001b[m"]
[144.640942, "o", "\r\n\u001b[7m Manual page nmcli(1) line 166 (press h for help or q to quit)\u001b[27m\u001b[K"]
[145.137831, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Update DNS configuration, which usually involves writing\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 167 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               /etc/resolv.conf anew. This is equivalent to sending the SIGUSR1\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 168 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               signal to the NetworkManager process.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 169 (press h for help or q to quit)\u001b[27m\u001b[K"]
[145.14761299999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[145.147849, "o", "\u001b[m\r\n"]
[145.147875, "o", "\u001b[7m Manual page nmcli(1) line 170 (press h for help or q to quit)\u001b[27m\u001b[K"]
