[151.39149699999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mACTIVITY MONITOR\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 233 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.39207799999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mnmcli monitor\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 234 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.39252299999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 235 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.42550599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       Observe NetworkManager activity. Watches for changes in connectivity state,\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 236 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       devices or connection profiles.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 237 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.427057, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 238 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.453062, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       See also \u001b[1mnmcli connection monitor \u001b[22mand \u001b[1mnmcli device monitor \u001b[22mto watch for\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 239 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.453552, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[151.45367399999998, "o", "       changes in certain devices or connections.\u001b[m"]
[151.453868, "o", "\r\n\u001b[7m Manual page nmcli(1) line 240 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[151.45390599999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 241 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.473591, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mCONNECTION MANAGEMENT COMMANDS\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 242 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[151.473951, "o", "       \u001b[1mnmcli connection \u001b[22m{\u001b[1mshow \u001b[22m| \u001b[1mup \u001b[22m| \u001b[1mdown \u001b[22m| \u001b[1mmodify \u001b[22m| \u001b[1madd \u001b[22m| \u001b[1medit \u001b[22m| \u001b[1mclone \u001b[22m| \u001b[1mdelete \u001b[22m|\u001b[m"]
[151.473992, "o", "\r\n\u001b[7m Manual page nmcli(1) line 243 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                        \u001b[1mmonitor \u001b[22m| \u001b[1mreload \u001b[22m| \u001b[1mload \u001b[22m| \u001b[1mimport \u001b[22m| \u001b[1mexport \u001b[22m| \u001b[1mmigrate\u001b[22m}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 244 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.511575, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[151.51232799999997, "o", "                        [\u001b[4mARGUMENTS\u001b[24m...]\u001b[m"]
[151.51243399999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 245 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 246 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       NetworkManager stores all network configuration as \"connections\", which are\u001b[m"]
[151.51252499999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 247 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.630718, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[152.632364, "o", "       collections of data (Layer2 details, IP addressing, etc.) that describe how to\u001b[m"]
[152.63296199999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 248 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       create or connect to a network. A connection is \"active\" when a device uses\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 249 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       that connection's configuration to create or connect to a network. There may\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 250 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.67181799999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[152.672439, "o", "       be multiple connections that apply to a device, but only one of them can be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 251 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.67473999999999, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[152.67543, "o", "       active on that device at any given time. The additional connections can be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 252 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       used to allow quick switching between different networks and configurations.\u001b[m"]
[152.67618399999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 253 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.693582, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[152.694235, "o", "\r\n\u001b[7m Manual page nmcli(1) line 254 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[152.695041, "o", "       Consider a machine which is usually connected to a DHCP-enabled network, but\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 255 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       sometimes connected to a testing network which uses static IP addressing.\u001b[m\r\n"]
[152.695113, "o", "\u001b[7m Manual page nmcli(1) line 256 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.71339899999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[152.71384999999998, "o", "       Instead of manually reconfiguring eth0 each time the network is changed, the\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 257 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       settings can be saved as two connections which both apply to eth0, one for\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 258 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       DHCP (called default) and one with the static addressing details (called\u001b[m"]
[152.71387999999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 259 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.731786, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[152.73221999999998, "o", "       testing). When connected to the DHCP-enabled network the user would run \u001b[1mnmcli\u001b[0m\u001b[m"]
[152.732754, "o", "\r\n\u001b[7m Manual page nmcli(1) line 260 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mcon up default \u001b[22m, and when connected to the static network the user would run\u001b[m\r\n"]
[152.73280999999997, "o", "\u001b[7m Manual page nmcli(1) line 261 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[152.73551099999997, "o", "       \u001b[1mnmcli con up testing\u001b[22m.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 262 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.75118499999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[152.751287, "o", "\u001b[m"]
[152.751311, "o", "\r\n"]
[152.75133499999998, "o", "\u001b[7m Manual page nmcli(1) line 263 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.75196899999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mshow \u001b[22m[\u001b[1m--active\u001b[22m] [\u001b[1m--order \u001b[22m[+-]\u001b[4mcategory\u001b[24m:...]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 264 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.752184, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           List in-memory and on-disk connection profiles, some of which may also be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 265 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.83522899999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           active if a device is using that connection profile. Without a parameter,\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 266 (press h for help or q to quit)\u001b[27m\u001b[K"]
[152.83592899999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           all profiles are listed. When \u001b[1m--active \u001b[22moption is specified, only the\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 267 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           active profiles are shown.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 268 (press h for help or q to quit)\u001b[27m\u001b[K"]
[153.30384299999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 269 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The \u001b[1m--order \u001b[22moption can be used to get custom ordering of connections. The\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 270 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           connections can be ordered by active status (active), name (name), type\u001b[m"]
[153.304283, "o", "\r\n\u001b[7m Manual page nmcli(1) line 271 (press h for help or q to quit)\u001b[27m\u001b[K"]
[153.32509499999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           (type) or D-Bus path (path). If connections are equal according to a sort\u001b[m"]
[153.325718, "o", "\r\n\u001b[7m Manual page nmcli(1) line 272 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           order category, an additional category can be specified. The default\u001b[m"]
[153.32578, "o", "\r\n\u001b[7m Manual page nmcli(1) line 273 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           sorting order is equivalent to --order active:name:path.  + or no prefix\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 274 (press h for help or q to quit)\u001b[27m\u001b[K"]
[153.34661599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           means sorting in ascending order (alphabetically or in numbers), - means\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 275 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[153.347307, "o", "           reverse (descending) order. The category names can be abbreviated (e.g.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 276 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[153.34749599999998, "o", "           --order -a:na).\u001b[m"]
[153.34824399999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 277 (press h for help or q to quit)\u001b[27m\u001b[K"]
[153.36713499999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 278 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mshow \u001b[22m[\u001b[1m--active\u001b[22m] [\u001b[1mid \u001b[22m| \u001b[1muuid \u001b[22m| \u001b[1mpath \u001b[22m| \u001b[1mapath\u001b[22m] \u001b[4mID\u001b[24m...\u001b[m"]
[153.36771399999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 279 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[153.36791, "o", "           Show details for specified connections. By default, both static\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 280 (press h for help or q to quit)\u001b[27m\u001b[K"]
