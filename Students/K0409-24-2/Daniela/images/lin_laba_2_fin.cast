[166.41130999999996, "o", "       \u2022   Servers, headless machines, and terminals: \u001b[1mnmcli \u001b[22mcan be used to control\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 3 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           NetworkManager without a GUI, including creating, editing, starting and\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
[167.11898099999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           stopping network connections and viewing network status.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 5 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 6 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[167.13873399999994, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-a \u001b[22m| \u001b[1m--ask\u001b[0m\u001b[m"]
[167.13931799999995, "o", "\r\n\u001b[7m Manual page nmcli(1) line 8 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           When using this option \u001b[1mnmcli \u001b[22mwill stop and ask for any missing required\u001b[m"]
[167.13960599999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           arguments, so do not use this option for non-interactive purposes like\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
[167.167781, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           scripts. This option controls, for example, whether you will be prompted\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 11 (press h for help or q to quit)\u001b[27m\u001b[K"]
[167.169761, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           for a password if it is required for connecting to a network.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 12 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 13 (press h for help or q to quit)\u001b[27m\u001b[K"]
[168.65597599999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[168.65649799999994, "o", "       \u001b[1m-c \u001b[22m| \u001b[1m--colors \u001b[22m{yes | no | auto}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 14 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option controls color output (using terminal escape sequences).  yes\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 15 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           enables colors, no disables them, auto only produces colors when standard\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 16 (press h for help or q to quit)\u001b[27m\u001b[K"]
[168.66326399999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[168.66369799999995, "o", "           output is directed to a terminal. The default value is auto.\u001b[m\r\n"]
