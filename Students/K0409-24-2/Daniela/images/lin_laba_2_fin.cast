[141.86334999999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 126 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mstatus\u001b[0m\u001b[m"]
[141.86360299999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 127 (press h for help or q to quit)\u001b[27m\u001b[K"]
