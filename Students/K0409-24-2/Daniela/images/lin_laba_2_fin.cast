[157.56736, "o", "\u001b[H\u001bM           Reload NetworkManager's configuration and perform certain updates, like\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 176 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mreload \u001b[22m[\u001b[4mflags\u001b[24m...]\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 175 (press h for help or q to quit)\u001b[27m\u001b[K"]
