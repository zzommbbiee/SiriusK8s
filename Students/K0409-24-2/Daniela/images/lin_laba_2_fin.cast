[146.26423499999999, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           managed by NetworkManager are deactivated when networking is disabled.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 189 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 190 (press h for help or q to quit)\u001b[27m\u001b[K"]
