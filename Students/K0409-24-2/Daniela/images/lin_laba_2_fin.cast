[133.16392100000002, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option is used to specify what fields (column names) should be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 46 (press h for help or q to quit)\u001b[27m\u001b[K"]
[133.19294200000002, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           printed. Valid field names differ for specific commands. List available\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 47 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           fields by providing an invalid value to the \u001b[1m--fields \u001b[22moption.  all is used\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 48 (press h for help or q to quit)\u001b[27m\u001b[K"]
[133.19354799999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           to print all valid field values of the command.  common is used to print\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 49 (press h for help or q to quit)\u001b[27m\u001b[K"]
[133.215551, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           common field values of the command.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 50 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[133.216549, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 51 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If omitted, default is common.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 52 (press h for help or q to quit)\u001b[27m\u001b[K"]
[133.25660599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 53 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-g \u001b[22m| \u001b[1m--get-values \u001b[22m{\u001b[4mfield1\u001b[24m,\u001b[4mfield2\u001b[24m... | all | common}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 54 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option is used to print values from specific fields. It is basically\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 55 (press h for help or q to quit)\u001b[27m\u001b[K"]
[134.023055, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           a shortcut for --mode tabular --terse --fields and is a convenient way to\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 56 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           retrieve values for particular fields. The values are printed one per line\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 57 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           without headers.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 58 (press h for help or q to quit)\u001b[27m\u001b[K"]
[134.06511, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 59 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If a section is specified instead of a field, the section name will be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 60 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           printed followed by colon separated values of the fields belonging to that\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 61 (press h for help or q to quit)\u001b[27m\u001b[K"]
[134.094563, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
