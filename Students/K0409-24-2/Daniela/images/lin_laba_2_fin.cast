[145.189981, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           With no flags, everything that is supported is reloaded, which is\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 178 (press h for help or q to quit)\u001b[27m\u001b[K"]
[145.21448599999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           identical to sending a SIGHUP. See \u001b[1mNetworkManager\u001b[22m(8) for more details\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 179 (press h for help or q to quit)\u001b[27m\u001b[K"]
[145.21526999999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           about signals.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 180 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 181 (press h for help or q to quit)\u001b[27m\u001b[K"]
