[148.916518, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mwifi \u001b[22m[on | off]\u001b[m"]
[148.91682399999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 221 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[148.917012, "o", "           Show or set status of Wi-Fi in NetworkManager. If no arguments are\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 222 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           supplied, Wi-Fi status is printed; \u001b[1mon \u001b[22menables Wi-Fi; \u001b[1moff \u001b[22mdisables Wi-Fi.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 223 (press h for help or q to quit)\u001b[27m\u001b[K"]
[148.95788799999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 224 (press h for help or q to quit)\u001b[27m\u001b[K"]
[148.958307, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mwwan \u001b[22m[on | off]\u001b[m"]
[148.95855799999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 225 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show or set status of WWAN (mobile broadband) in NetworkManager. If no\u001b[m"]
[148.959155, "o", "\r\n\u001b[7m Manual page nmcli(1) line 226 (press h for help or q to quit)\u001b[27m\u001b[K"]
[150.914805, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[150.916385, "o", "           arguments are supplied, mobile broadband status is printed; \u001b[1mon \u001b[22menables\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 227 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           mobile broadband, \u001b[1moff \u001b[22mdisables it.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 228 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 229 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.361424, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[151.361652, "o", "       \u001b[1mall \u001b[22m[on | off]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 230 (press h for help or q to quit)\u001b[27m\u001b[K"]
[151.362232, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show or set all previously mentioned radio switches at the same time.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 231 (press h for help or q to quit)\u001b[27m\u001b[K"]
