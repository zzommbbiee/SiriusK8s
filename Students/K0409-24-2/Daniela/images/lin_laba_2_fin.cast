[157.534721, "o", "\u001b[H\u001bM           Available flags are:\u001b[m"]
[157.534767, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 181 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.550274, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.5505, "o", "\u001b[H\u001bM           non-root access via PolicyKit and contrary to signals it is synchronous.\u001b[m"]
[157.550767, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 180 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           control over what to reload through the flags argument. It also allows\u001b[m"]
[157.55079899999998, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 179 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           sending SIGHUP to NetworkManager but it allows for more fine-grained\u001b[m"]
[157.55141099999997, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 178 (press h for help or q to quit)\u001b[27m\u001b[K"]
