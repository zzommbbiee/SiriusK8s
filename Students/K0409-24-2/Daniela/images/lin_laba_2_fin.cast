[157.74881899999997, "o", "\u001b[H\u001bM       \u001b[1mnmcli general \u001b[22m{\u001b[1mstatus \u001b[22m| \u001b[1mhostname \u001b[22m| \u001b[1mpermissions \u001b[22m| \u001b[1mlogging \u001b[22m| \u001b[1mreload\u001b[22m}\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 142 (press h for help or q to quit)\u001b[27m\u001b[K"]
