[157.735075, "o", "\u001b[H\u001bM       get and change system hostname, as well as NetworkManager logging level and\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 146 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.735092, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.73621299999996, "o", "\u001b[H\u001bM       Use this command to show NetworkManager status and permissions. You can also\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 145 (press h for help or q to quit)\u001b[27m\u001b[K"]
