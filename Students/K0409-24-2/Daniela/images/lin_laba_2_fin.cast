[126.918626, "o", "NMCLI(1)                       General Commands Manual                       NMCLI(1)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       nmcli - command-line tool for controlling NetworkManager\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mnmcli \u001b[22m[\u001b[4mOPTIONS\u001b[24m...] {\u001b[1mhelp \u001b[22m| \u001b[1mgeneral \u001b[22m| \u001b[1mnetworking \u001b[22m| \u001b[1mradio \u001b[22m| \u001b[1mconnection \u001b[22m| \u001b[1mdevice\u001b[0m\u001b[m\r\n             | \u001b[1magent \u001b[22m| \u001b[1mmonitor\u001b[22m} [\u001b[4mCOMMAND\u001b[24m] [\u001b[4mARGUMENTS\u001b[24m...]\u001b[m\r\n\u001b[m\r\n\u001b[1mDESCRIPTION\u001b[0m\u001b[m\r\n       \u001b[1mnmcli \u001b[22mis a command-line tool for controlling NetworkManager and reporting\u001b[m\r\n       network status. It can be utilized as a replacement for \u001b[1mnm-applet \u001b[22mor other\u001b[m\r\n       graphical clients.  \u001b[1mnmcli \u001b[22mis used to create, display, edit, delete, activate,\u001b[m\r\n       and deactivate network connections, as well as control and display network\u001b[m\r\n       device status. See \u001b[1mnmcli-examples\u001b[22m(7) for ready to run nmcli examples.\u001b[m\r\n\u001b[m\r\n       Typical uses include:\u001b[m\r\n\u001b[m\r\n       \u2022   Scripts: Util"]
[126.91872799999997, "o", "ize NetworkManager via \u001b[1mnmcli \u001b[22minstead of managing network\u001b[m\r\n           connections manually.  \u001b[1mnmcli \u001b[22msupports a terse output format which is\u001b[m\r\n           better suited for script processing. Note that NetworkManager can also\u001b[m\r\n           execute scripts, called \"dispatcher scripts\", in response to network\u001b[m\r\n           events. See \u001b[1mNetworkManager\u001b[22m(8) for details about these dispatcher scripts.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 1 (press h for help or q to quit)\u001b[27m\u001b[K"]
[129.918728, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[129.91929999999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 2 (press h for help or q to quit)\u001b[27m\u001b[K"]
[129.91954399999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u2022   Servers, headless machines, and terminals: \u001b[1mnmcli \u001b[22mcan be used to control\u001b[m"]
[129.92007999999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 3 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           NetworkManager without a GUI, including creating, editing, starting and\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 4 (press h for help or q to quit)\u001b[27m\u001b[K"]
[129.946685, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[129.94709799999998, "o", "           stopping network connections and viewing network status.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 5 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 6 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 7 (press h for help or q to quit)\u001b[27m\u001b[K"]
[129.976341, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-a \u001b[22m| \u001b[1m--ask\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 8 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           When using this option \u001b[1mnmcli \u001b[22mwill stop and ask for any missing required\u001b[m"]
[129.977552, "o", "\r\n\u001b[7m Manual page nmcli(1) line 9 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[129.977617, "o", "           arguments, so do not use this option for non-interactive purposes like\u001b[m"]
[129.978544, "o", "\r\n"]
[129.97888799999998, "o", "\u001b[7m Manual page nmcli(1) line 10 (press h for help or q to quit)\u001b[27m\u001b[K"]
[130.023347, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           scripts. This option controls, for example, whether you will be prompted\u001b[m\r\n"]
[130.023456, "o", "\u001b[7m Manual page nmcli(1) line 11 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[130.023481, "o", "           for a password if it is required for connecting to a network.\u001b[m"]
[130.023546, "o", "\r\n\u001b[7m Manual page nmcli(1) line 12 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[130.02402899999998, "o", "\u001b[m\r\n"]
[130.02439599999997, "o", "\u001b[7m Manual page nmcli(1) line 13 (press h for help or q to quit)\u001b[27m\u001b[K"]
[130.74028299999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-c \u001b[22m| \u001b[1m--colors \u001b[22m{yes | no | auto}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 14 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option controls color output (using terminal escape sequences).  yes\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 15 (press h for help or q to quit)\u001b[27m\u001b[K"]
[130.74035299999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           enables colors, no disables them, auto only produces colors when standard\u001b[m"]
[130.74037299999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 16 (press h for help or q to quit)\u001b[27m\u001b[K"]
[130.77124700000002, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           output is directed to a terminal. The default value is auto.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 17 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 18 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The actual colors used are configured as described in \u001b[1mterminal-\u001b[0m\u001b[m"]
[130.771339, "o", "\r\n\u001b[7m Manual page nmcli(1) line 19 (press h for help or q to quit)\u001b[27m\u001b[K"]
[130.78796, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[130.78872, "o", "           \u001b[1mcolors.d\u001b[22m(5). Please refer to the COLORS section for a list of color names\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 20 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           supported by \u001b[1mnmcli\u001b[22m.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 21 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[130.78892100000002, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[130.81917099999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[130.82005599999997, "o", "           If the environment variable NO_COLOR is set (to any non-empty value), then\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 23 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           coloring is disabled with mode \"auto\". If the environment variable\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 24 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           CLICOLOR_FORCE is set (to any non-empty value), then coloring is enabled\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 25 (press h for help or q to quit)\u001b[27m\u001b[K"]
[130.851612, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[130.85335700000002, "o", "           with mode \"auto\". Explicitly enabling coloring overrides the environment\u001b[m\r\n"]
[130.85354999999998, "o", "\u001b[7m Manual page nmcli(1) line 26 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           variable.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 27 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[130.85368999999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[131.85243199999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           stopping network connections and viewing network status.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 27 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           NetworkManager without a GUI, including creating, editing, starting and\u001b[m"]
[131.852576, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 26 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[131.85263299999997, "o", "\u001b[H\u001bM       \u2022   Servers, headless machines, and terminals: \u001b[1mnmcli \u001b[22mcan be used to control\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 25 (press h for help or q to quit)\u001b[27m\u001b[K"]
[131.89753000000002, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[131.898015, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 24 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           events. See \u001b[1mNetworkManager\u001b[22m(8) for details about these dispatcher scripts.\u001b[m"]
[131.898595, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 23 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           execute scripts, called \"dispatcher scripts\", in response to network\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[132.54875199999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[132.549032, "o", "           If the environment variable NO_COLOR is set (to any non-empty value), then\u001b[m"]
[132.549061, "o", "\r\n\u001b[7m Manual page nmcli(1) line 23 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[132.549153, "o", "           coloring is disabled with mode \"auto\". If the environment variable\u001b[m\r\n"]
[132.549437, "o", "\u001b[7m Manual page nmcli(1) line 24 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           CLICOLOR_FORCE is set (to any non-empty value), then coloring is enabled\u001b[m"]
[132.54969699999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 25 (press h for help or q to quit)\u001b[27m\u001b[K"]
[132.561603, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[132.561981, "o", "           with mode \"auto\". Explicitly enabling coloring overrides the environment\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 26 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           variable.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 27 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[132.579973, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[132.58009299999998, "o", "       \u001b[1m--complete-args\u001b[0m\u001b[m"]
[132.580128, "o", "\r\n"]
[132.58016099999998, "o", "\u001b[7m Manual page nmcli(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K"]
[132.58030200000002, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Instead of conducting the desired action, \u001b[1mnmcli \u001b[22mwill list possible\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           completions for the last argument. This is useful to implement argument\u001b[m"]
[132.580334, "o", "\r\n"]
[132.58036699999997, "o", "\u001b[7m Manual page nmcli(1) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[132.596627, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           completion in shell.\u001b[m"]
[132.597468, "o", "\r\n\u001b[7m Manual page nmcli(1) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 33 (press h for help or q to quit)\u001b[27m\u001b[K"]
[132.598234, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The exit status will indicate success or return a code 65 to indicate the\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
[132.621065, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           last argument is a file name.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 35 (press h for help or q to quit)\u001b[27m\u001b[K"]
