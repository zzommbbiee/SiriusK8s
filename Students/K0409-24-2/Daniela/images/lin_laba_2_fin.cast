[156.08987099999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               some networks may require credentials during activation. You can give\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 344 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[156.09020899999996, "o", "               these credentials using this option. Each line of the file should\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 345 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               contain one password in the form:\u001b[m"]
[156.09042599999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 346 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.11731699999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[156.11775899999998, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 347 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   setting_name.property_name:the password\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 348 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.118107, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 349 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.15459299999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               For example, for WPA Wi-Fi with PSK, the line would be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 350 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.15817199999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 351 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   802-11-wireless-security.psk:secret12345\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 352 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.223658, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 353 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.22407099999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               For 802.1X password, the line would be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 354 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
