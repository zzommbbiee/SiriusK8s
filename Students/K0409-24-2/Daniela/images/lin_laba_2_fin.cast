[134.67484100000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Output is a table where each line describes a single entry. Columns\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 71 (press h for help or q to quit)\u001b[27m\u001b[K"]
[134.67521599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               define particular properties of the entry.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 72 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
