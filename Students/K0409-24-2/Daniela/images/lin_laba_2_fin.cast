[156.90974799999998, "o", "\u001b[H\u001bM           \u001b[1mapath\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 321 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.910528, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 320 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               /org/freedesktop/NetworkManager/Settings/\u001b[4mnum\u001b[24m or just \u001b[4mnum\u001b[24m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 319 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.92459299999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.92504099999996, "o", "\u001b[H\u001bM               the \u001b[4mID\u001b[24m denotes a D-Bus static connection path in the format of\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 318 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.925477, "o", "\u001b[H\u001bM           \u001b[1mpath\u001b[0m\u001b[m"]
[156.92672999999996, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 317 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 316 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.94064399999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.94107299999996, "o", "\u001b[H\u001bM               the \u001b[4mID\u001b[24m denotes a connection UUID.\u001b[m"]
[156.941218, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 315 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.941392, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.94165799999996, "o", "\u001b[H\u001bM           \u001b[1muuid\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 314 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.94354399999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 313 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.955128, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               the \u001b[4mID\u001b[24m denotes a connection name.\u001b[m"]
[156.95559699999995, "o", "\r\n"]
[156.955963, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 312 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.957469, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.957695, "o", "\u001b[H\u001bM           \u001b[1mid\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 311 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 310 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.97346899999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[4mID\u001b[24m-specifying keywords are:\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 309 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.974134, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mid\u001b[22m, \u001b[1muuid\u001b[22m, \u001b[1mpath \u001b[22mand \u001b[1mapath \u001b[22mkeywords can be used if \u001b[4mID\u001b[24m is ambiguous. Optional\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 308 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n"]
[156.97429599999998, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 307 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.98755999999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.98892899999998, "o", "\u001b[H\u001bM           profile.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 306 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.98951999999997, "o", "\u001b[H\u001bM           global \u001b[1m--show-secrets \u001b[22moption to display secrets associated with the\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 305 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           option is specified, only the active profiles are taken into account. Use\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 304 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.00262199999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           configuration and active connection data are displayed. When \u001b[1m--active\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 303 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Show details for specified connections. By default, both static\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 302 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mshow \u001b[22m[\u001b[1m--active\u001b[22m] [\u001b[1mid \u001b[22m| \u001b[1muuid \u001b[22m| \u001b[1mpath \u001b[22m| \u001b[1mapath\u001b[22m] \u001b[4mID\u001b[24m...\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 301 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.018751, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 300 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           --order -a:na).\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 299 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.019002, "o", "\u001b[H\u001bM           reverse (descending) order. The category names can be abbreviated (e.g.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 298 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.03224899999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.032531, "o", "\u001b[H\u001bM           means sorting in ascending order (alphabetically or in numbers), - means\u001b[m"]
[157.033033, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 297 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.03311099999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.03346299999998, "o", "\u001b[H\u001bM           sorting order is equivalent to --order active:name:path.  + or no prefix\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 296 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.03351399999997, "o", "\u001b[H\u001bM           order category, an additional category can be specified. The default\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 295 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.04835099999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.04938399999998, "o", "\u001b[H\u001bM           (type) or D-Bus path (path). If connections are equal according to a sort\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 294 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           connections can be ordered by active status (active), name (name), type\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 293 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           The \u001b[1m--order \u001b[22moption can be used to get custom ordering of connections. The\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 292 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.06293, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.06329999999997, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 291 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           active profiles are shown.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 290 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           all profiles are listed. When \u001b[1m--active \u001b[22moption is specified, only the\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 289 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.080444, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           active if a device is using that connection profile. Without a parameter,\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 288 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.08052499999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           List in-memory and on-disk connection profiles, some of which may also be\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 287 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mshow \u001b[22m[\u001b[1m--active\u001b[22m] [\u001b[1m--order \u001b[22m[+-]\u001b[4mcategory\u001b[24m:...]\u001b[m\r\n"]
[157.08055199999995, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 286 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.096793, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 285 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mnmcli con up testing\u001b[22m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 284 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mcon up default \u001b[22m, and when connected to the static network the user would run\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 283 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.114056, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       testing). When connected to the DHCP-enabled network the user would run \u001b[1mnmcli\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 282 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.114849, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.114915, "o", "\u001b[H\u001bM       DHCP (called default) and one with the static addressing details (called\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 281 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.11494, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.114964, "o", "\u001b[H\u001bM       settings can be saved as two connections which both apply to eth0, one for\u001b[m\r\n"]
[157.114986, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 280 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.12798299999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.12833999999998, "o", "\u001b[H\u001bM       Instead of manually reconfiguring eth0 each time the network is changed, the\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 279 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.12879099999998, "o", "\u001b[H\u001bM       sometimes connected to a testing network which uses static IP addressing.\u001b[m"]
[157.12992199999997, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 278 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Consider a machine which is usually connected to a DHCP-enabled network, but\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 277 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.139204, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.13926399999997, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 276 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.13928199999998, "o", "\u001b[H\u001bM       used to allow quick switching between different networks and configurations.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 275 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.139992, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[157.14003099999996, "o", "\u001b[H\u001bM       active on that device at any given time. The additional connections can be\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 274 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.15047099999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       be multiple connections that apply to a device, but only one of them can be\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 273 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.151046, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       that connection's configuration to create or connect to a network. There may\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 272 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       create or connect to a network. A connection is \"active\" when a device uses\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 271 (press h for help or q to quit)\u001b[27m\u001b[K"]
[157.160777, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
