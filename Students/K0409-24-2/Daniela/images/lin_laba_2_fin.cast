[156.808984, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           keywords.\u001b[m"]
[156.809058, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 354 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           See \u001b[1mconnection show \u001b[22mabove for the description of the \u001b[4mID\u001b[24m-specifying\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 353 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 352 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.81886499999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.819139, "o", "\u001b[H\u001bM           If \u001b[1m--wait \u001b[22moption is not specified, the default timeout will be 90 seconds.\u001b[m"]
[156.81919999999997, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 351 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m"]
[156.81956199999996, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 350 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.81960299999997, "o", "\u001b[H\u001bM           what particular AP should be used in case of a Wi-Fi connection.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 349 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           option specifies the device of the base connection. The \u001b[1map \u001b[22moption specify\u001b[m"]
[156.819836, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 348 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           connection for the given \u001b[1mifname\u001b[22m. In case of a VPN connection, the \u001b[1mifname\u001b[0m\u001b[m"]
[156.819862, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 347 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.81998299999998, "o", "\u001b[H\u001bM           an \u001b[1mifname \u001b[22mis required, and NetworkManager will activate the best available\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 346 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.826103, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mifname \u001b[22moption with interface name should be given. If the \u001b[4mID\u001b[24m is not given\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 345 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           When requiring a particular device to activate the connection on, the\u001b[m"]
[156.826365, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 344 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.82644399999998, "o", "\u001b[H\u001bM           D-Bus path. If \u001b[4mID\u001b[24m is ambiguous, a keyword \u001b[1mid\u001b[22m, \u001b[1muuid \u001b[22mor \u001b[1mpath \u001b[22mcan be used.\u001b[m"]
[156.826504, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 343 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.84146599999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Activate a connection. The connection is identified by its name, UUID or\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 342 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.84178299999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.844429, "o", "\u001b[H\u001bM       \u001b[1mup \u001b[22m[\u001b[1mid \u001b[22m| \u001b[1muuid \u001b[22m| \u001b[1mpath\u001b[22m] \u001b[4mID\u001b[24m [\u001b[1mifname \u001b[4m\u001b[22mifname\u001b[24m] [\u001b[1map \u001b[4m\u001b[22mBSSID\u001b[24m] [\u001b[1mpasswd-file \u001b[4m\u001b[22mfile\u001b[24m]\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 341 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 340 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mnmcli connection show\u001b[22m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 339 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           When no command is given to the \u001b[1mnmcli connection\u001b[22m, the default action is\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 338 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 337 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.85578199999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           page. For active data use GENERAL, IP4, DHCP4, IP6, DHCP6, VPN.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 336 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.856496, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.85684099999997, "o", "\u001b[H\u001bM           setting and property names as described in \u001b[1mnm-settings-nmcli\u001b[22m(5) manual\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 335 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           You can also specify particular fields. For static configuration, use\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 334 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 333 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               only shows active connection data (when the profile is active).\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 332 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mactive\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 331 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.868269, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.868985, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 330 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.869374, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               only shows static profile configuration.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 329 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.86951599999998, "o", "\u001b[H\u001bM           \u001b[1mprofile\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 328 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.87039399999998, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 327 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.87151899999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           the following values:\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 326 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.87215299999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           It is possible to filter the output using the global \u001b[1m--fields \u001b[22moption. Use\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 325 (press h for help or q to quit)\u001b[27m\u001b[K"]
[156.88212, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.883084, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 324 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[156.88313, "o", "\u001b[H\u001bM               /org/freedesktop/NetworkManager/ActiveConnection/\u001b[4mnum\u001b[24m or just \u001b[4mnum\u001b[24m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 323 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               the \u001b[4mID\u001b[24m denotes a D-Bus active connection path in the format of\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 322 (press h for help or q to quit)\u001b[27m\u001b[K"]
