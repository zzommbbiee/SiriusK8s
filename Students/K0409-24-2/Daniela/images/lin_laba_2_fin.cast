[168.68598099999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 20 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           supported by \u001b[1mnmcli\u001b[22m.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 21 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[168.68602699999997, "o", "\u001b[m"]
[168.68604999999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[168.70925799999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If the environment variable NO_COLOR is set (to any non-empty value), then\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 23 (press h for help or q to quit)\u001b[27m\u001b[K"]
[168.70956399999994, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           coloring is disabled with mode \"auto\". If the environment variable\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 24 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           CLICOLOR_FORCE is set (to any non-empty value), then coloring is enabled\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 25 (press h for help or q to quit)\u001b[27m\u001b[K"]
[168.71414199999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           with mode \"auto\". Explicitly enabling coloring overrides the environment\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 26 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           variable.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 27 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[168.735461, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--complete-args\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Instead of conducting the desired action, \u001b[1mnmcli \u001b[22mwill list possible\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           completions for the last argument. This is useful to implement argument\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[168.76395499999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           completion in shell.\u001b[m"]
[168.76426999999995, "o", "\r\n\u001b[7m Manual page nmcli(1) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 33 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The exit status will indicate success or return a code 65 to indicate the\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
[169.28817599999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[169.28913799999998, "o", "\u001b[H\u001bM           scripts. This option controls, for example, whether you will be prompted\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 33 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           arguments, so do not use this option for non-interactive purposes like\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           When using this option \u001b[1mnmcli \u001b[22mwill stop and ask for any missing required\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[169.33035299999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-a \u001b[22m| \u001b[1m--ask\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K"]
[169.33111999999994, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[171.72638299999994, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--complete-args\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Instead of conducting the desired action, \u001b[1mnmcli \u001b[22mwill list possible\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[171.72663899999998, "o", "           completions for the last argument. This is useful to implement argument\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[172.44915699999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           completion in shell.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 33 (press h for help or q to quit)\u001b[27m\u001b[K"]
[172.44939599999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The exit status will indicate success or return a code 65 to indicate the\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
[172.47013299999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[172.47037999999998, "o", "           last argument is a file name.\u001b[m"]
[172.47083999999995, "o", "\r\n\u001b[7m Manual page nmcli(1) line 35 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 36 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           NetworkManager ships with command completion support for GNU Bash.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 37 (press h for help or q to quit)\u001b[27m\u001b[K"]
[172.51466799999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[172.51498799999996, "o", "\u001b[m"]
[172.516258, "o", "\r\n\u001b[7m Manual page nmcli(1) line 38 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-e \u001b[22m| \u001b[1m--escape \u001b[22m{yes | no}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 39 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Whether to escape : and \\ characters in terse tabular mode. The escape\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 40 (press h for help or q to quit)\u001b[27m\u001b[K"]
[172.54810899999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[172.54905299999996, "o", "           character is \\.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 41 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 42 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If omitted, default is yes.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 43 (press h for help or q to quit)\u001b[27m\u001b[K"]
[173.26418399999994, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 44 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-f \u001b[22m| \u001b[1m--fields \u001b[22m{\u001b[4mfield1\u001b[24m,\u001b[4mfield2\u001b[24m... | all | common}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 45 (press h for help or q to quit)\u001b[27m\u001b[K"]
[173.26577799999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option is used to specify what fields (column names) should be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 46 (press h for help or q to quit)\u001b[27m\u001b[K"]
[173.28454799999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[173.28472699999998, "o", "           printed. Valid field names differ for specific commands. List available\u001b[m"]
[173.28572299999996, "o", "\r\n"]
[173.28629399999994, "o", "\u001b[7m Manual page nmcli(1) line 47 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[173.28637299999997, "o", "           fields by providing an invalid value to the \u001b[1m--fields \u001b[22moption.  all is used\u001b[m"]
[173.28677699999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 48 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           to print all valid field values of the command.  common is used to print\u001b[m"]
[173.28686199999999, "o", "\r\n\u001b[7m Manual page nmcli(1) line 49 (press h for help or q to quit)\u001b[27m\u001b[K"]
[173.31381, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[173.31431299999997, "o", "           common field values of the command.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 50 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[173.31435, "o", "\u001b[m"]
[173.31624999999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 51 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If omitted, default is common.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 52 (press h for help or q to quit)\u001b[27m\u001b[K"]
[173.33035399999994, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 53 (press h for help or q to quit)\u001b[27m\u001b[K"]
[173.33151299999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-g \u001b[22m| \u001b[1m--get-values \u001b[22m{\u001b[4mfield1\u001b[24m,\u001b[4mfield2\u001b[24m... | all | common}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 54 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option is used to print values from specific fields. It is basically\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 55 (press h for help or q to quit)\u001b[27m\u001b[K"]
[173.35774499999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           a shortcut for --mode tabular --terse --fields and is a convenient way to\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 56 (press h for help or q to quit)\u001b[27m\u001b[K"]
[173.35797799999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           retrieve values for particular fields. The values are printed one per line\u001b[m"]
[173.35804299999995, "o", "\r\n"]
[173.358749, "o", "\u001b[7m Manual page nmcli(1) line 57 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[173.35889499999996, "o", "           without headers.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 58 (press h for help or q to quit)\u001b[27m\u001b[K"]
[174.00809299999997, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[174.00860999999998, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 59 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If a section is specified instead of a field, the section name will be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 60 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           printed followed by colon separated values of the fields belonging to that\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 61 (press h for help or q to quit)\u001b[27m\u001b[K"]
[174.029296, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           section, all on the same line.\u001b[m"]
[174.02960099999996, "o", "\r\n\u001b[7m Manual page nmcli(1) line 62 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 63 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-h \u001b[22m| \u001b[1m--help\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 64 (press h for help or q to quit)\u001b[27m\u001b[K"]
[174.05891799999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[174.06018199999994, "o", "           Print help information.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 65 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 66 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-m \u001b[22m| \u001b[1m--mode \u001b[22m{tabular | multiline}\u001b[m"]
