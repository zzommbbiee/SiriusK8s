[155.00281999999999, "o", "\r\n\u001b[7m Manual page nmcli(1) line 302 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           It is possible to filter the output using the global \u001b[1m--fields \u001b[22moption. Use\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 303 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           the following values:\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 304 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.01399099999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 305 (press h for help or q to quit)\u001b[27m\u001b[K"]
