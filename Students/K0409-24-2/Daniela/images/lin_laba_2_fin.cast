[155.032289, "o", "\u001b[m"]
[155.03231599999998, "o", "\r\n\u001b[7m Manual page nmcli(1) line 311 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           You can also specify particular fields. For static configuration, use\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 312 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           setting and property names as described in \u001b[1mnm-settings-nmcli\u001b[22m(5) manual\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 313 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.05188099999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           page. For active data use GENERAL, IP4, DHCP4, IP6, DHCP6, VPN.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 314 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.05242999999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 315 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[155.052482, "o", "           When no command is given to the \u001b[1mnmcli connection\u001b[22m, the default action is\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 316 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.07243799999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
