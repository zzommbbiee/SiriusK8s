[155.07366199999996, "o", "       \u001b[1mup \u001b[22m[\u001b[1mid \u001b[22m| \u001b[1muuid \u001b[22m| \u001b[1mpath\u001b[22m] \u001b[4mID\u001b[24m [\u001b[1mifname \u001b[4m\u001b[22mifname\u001b[24m] [\u001b[1map \u001b[4m\u001b[22mBSSID\u001b[24m] [\u001b[1mpasswd-file \u001b[4m\u001b[22mfile\u001b[24m]\u001b[m"]
[155.07370099999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 319 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.08203699999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Activate a connection. The connection is identified by its name, UUID or\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 320 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.08236399999998, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[155.08239299999997, "o", "           D-Bus path. If \u001b[4mID\u001b[24m is ambiguous, a keyword \u001b[1mid\u001b[22m, \u001b[1muuid \u001b[22mor \u001b[1mpath \u001b[22mcan be used.\u001b[m"]
[155.08333699999997, "o", "\r\n\u001b[7m Manual page nmcli(1) line 321 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           When requiring a particular device to activate the connection on, the\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 322 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.12209099999995, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[155.12232, "o", "           \u001b[1mifname \u001b[22moption with interface name should be given. If the \u001b[4mID\u001b[24m is not given\u001b[m"]
[155.122343, "o", "\r\n\u001b[7m Manual page nmcli(1) line 323 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           an \u001b[1mifname \u001b[22mis required, and NetworkManager will activate the best available\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 324 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           connection for the given \u001b[1mifname\u001b[22m. In case of a VPN connection, the \u001b[1mifname\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 325 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.16455199999996, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[155.165299, "o", "           option specifies the device of the base connection. The \u001b[1map \u001b[22moption specify\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 326 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           what particular AP should be used in case of a Wi-Fi connection.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 327 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 328 (press h for help or q to quit)\u001b[27m\u001b[K"]
[155.26117, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If \u001b[1m--wait \u001b[22moption is not specified, the default timeout will be 90 seconds.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 329 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 330 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           See \u001b[1mconnection show \u001b[22mabove for the description of the \u001b[4mID\u001b[24m-specifying\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 331 (press h for help or q to quit)\u001b[27m\u001b[K"]
