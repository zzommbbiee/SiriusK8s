[60.566713, "o", "\r\u001b[2d\u001b(B\u001b[0;1m\u001b[36mimport\u001b[39m\u001b(B\u001b[m json\r\u001b[4dinput_file = \u001b(B\u001b[0;1m\u001b[32m'LABA_#1.cast'\r\u001b[5d\u001b[39m\u001b(B\u001b[moutput_file = \u001b(B\u001b[0;1m\u001b[32m'LABA_#1_final.cast'\r\u001b[7d\u001b[39m\u001b(B\u001b[mmax_idle = 1     \u001b(B\u001b[0;1m\u001b[31m # \u043c\u0430\u043a\u0441\u0438\u043c\u0430\u043b\u044c\u043d\u0430\u044f \u043f\u0430\u0443\u0437\u0430 \u0432 \u0441\u0435\u043a\u0443\u043d\u0434\u0430\u0445\r\u001b[8d\u001b[39m\u001b(B\u001b[mspeedup = 1.3    \u001b(B\u001b[0;1m\u001b[31m # \u0443\u0441\u043a\u043e\u0440\u0435\u043d\u0438\u0435 \u0432 1.3 \u0440\u0430\u0437\u0430\r\u001b[10d\u001b[36mwith\u001b[39m\u001b(B\u001b[m open(input_file, \u001b(B\u001b[0;1m\u001b[32m'r'\u001b[39m\u001b(B\u001b[m) \u001b(B\u001b[0;1m\u001b[36mas\u001b[39m\u001b(B\u001b[m f:\u001b[11;5Hlines = f.readlines()\r\u001b[13dheader = json.loads(lines[0])\r\u001b[14dheader[\u001b(B\u001b[0;1m\u001b[32m'idle_time_limit'\u001b[39m\u001b(B\u001b[m] = max_idle\r\u001b[16d"]
