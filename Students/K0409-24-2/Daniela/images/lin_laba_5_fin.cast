[72.494164, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This switch has an effect only on the \u001b[1mshort \u001b[22mfamily of output modes (see above).\u001b[m"]
[72.494214, "o", "\r\n\u001b[7m Manual page journalctl(1) line 367 (press h for help or q to quit)\u001b[27m\u001b[K"]
[72.536619, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
