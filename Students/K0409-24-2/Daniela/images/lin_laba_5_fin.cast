[137.72108200000002, "o", "\r\u001b[2d\u001b[36m#!/usr/bin/env bash\r\u001b[3d\u001b(B\u001b[0;1m\u001b[34mset\u001b[39m\u001b(B\u001b[m -euo pipefail\r\u001b[5dLAB\u001b[32m=\u001b(B\u001b[0;1m\u001b[33m\"/opt/break_lab\"\r\u001b[6d\u001b[34mmkdir\u001b[35m -p\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$LAB\"\r\u001b[8d\u001b[34mcat\u001b[39m\u001b(B\u001b[m \u001b[32m>\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$LAB/script_server.sh\"\u001b[39m\u001b(B\u001b[m \u001b[32m<<\u001b(B\u001b[0;1m\u001b[33m'EOF'\r\u001b[9d\u001b(B\u001b[0m\u001b[36m#!/usr/bin/env bash\r\u001b[10d\u001b(B\u001b[0;1m\u001b[34mset\u001b[39m\u001b(B\u001b[m -euo pipefail\r\u001b[11d\u001b(B\u001b[0;1m\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"script-server: \u0441\u0442\u0430\u0440\u0442 $(date -Is)\"\u001b[39m\u001b(B\u001b[m \u001b[32m>&\u001b[39m\u001b(B\u001b[m2\r\u001b[12d\u001b[32mexit\u001b[39m\u001b(B\u001b[m 1\r\u001b[13dEOF\r\u001b[14d"]
[137.72181400000002, "o", "\u001b(B\u001b[0;1m\u001b[34mchmod\u001b[39m\u001b(B\u001b[m +x \u001b(B\u001b[0;1m\u001b[33m\"$LAB/script_server.sh\"\r\u001b[16d\u001b[39m\u001b(B\u001b[mUNIT\u001b[32m=\u001b(B\u001b[0;1m\u001b[33m\"/etc/systemd/system/script-server.service\"\r\u001b[17d\u001b[34mcat\u001b[39m\u001b(B\u001b[m \u001b[32m>\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$UNIT\"\u001b[39m\u001b(B\u001b[m \u001b[32m<<\u001b[39m\u001b(B\u001b[mEOF\r\u001b[18d\u001b[32m[\u001b[39m\u001b(B\u001b[mUnit\u001b[32m]\r\u001b[19d\u001b[39m\u001b(B\u001b[mDescription\u001b[32m=\u001b[39m\u001b(B\u001b[mBreak Lab Script Server\r\u001b[20dAfter\u001b[32m=\u001b[39m\u001b(B\u001b[mnetwork.target\r\u001b[2d"]
