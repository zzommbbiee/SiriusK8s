[66.26822, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is very similar, but shows classic syslog timestamps with full microsecond\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 255 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               precision.\u001b[m"]
[66.268321, "o", "\r\n"]
[66.268356, "o", "\u001b[7m Manual page journalctl(1) line 256 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.677457, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[66.678079, "o", "\r\n\u001b[7m Manual page journalctl(1) line 257 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mshort-monotonic\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 258 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is very similar, but shows monotonic timestamps instead of wallclock\u001b[m"]
[66.678156, "o", "\r\n\u001b[7m Manual page journalctl(1) line 259 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.687927, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[66.68828, "o", "               timestamps.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 260 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.68841400000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 261 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mshort-delta\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 262 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.720195, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               as for \u001b[1mshort-monotonic \u001b[22mbut includes the time difference to the previous\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 263 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.720449, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               entry. Maybe unreliable time differences are marked by a \"*\".\u001b[m\r\n"]
[66.720532, "o", "\u001b[7m Manual page journalctl(1) line 264 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[66.72059, "o", "\u001b[m"]
[66.720713, "o", "\r\n\u001b[7m Manual page journalctl(1) line 265 (press h for help or q to quit)\u001b[27m\u001b[K"]
[66.74819600000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[66.748444, "o", "           \u001b[1mshort-unix\u001b[0m\u001b[m"]
[66.748587, "o", "\r\n\u001b[7m Manual page journalctl(1) line 266 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               is very similar, but shows seconds passed since January 1st 1970 UTC\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 267 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[66.7488, "o", "               instead of wallclock timestamps (\"UNIX time\"). The time is shown with\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 268 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.110845, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[67.11136400000001, "o", "               microsecond accuracy.\u001b[m"]
[67.111475, "o", "\r\n"]
