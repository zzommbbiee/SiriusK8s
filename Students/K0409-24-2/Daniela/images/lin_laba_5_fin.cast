[68.408669, "o", "\r\n\u001b[7m Manual page journalctl(1) line 314 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               generates a very terse output, only showing the actual message of each\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 315 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               journal entry with no metadata, not even a timestamp. If combined with the\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 316 (press h for help or q to quit)\u001b[27m\u001b[K"]
[68.52772, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[1m--output-fields= \u001b[22moption will output the listed fields for each log record,\u001b[m"]
[68.529145, "o", "\r\n\u001b[7m Manual page journalctl(1) line 317 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               instead of the message.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 318 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 319 (press h for help or q to quit)\u001b[27m\u001b[K"]
[68.64581700000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mwith-unit\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 320 (press h for help or q to quit)\u001b[27m\u001b[K"]
[68.646319, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               similar to \u001b[1mshort-full\u001b[22m, but prefixes the unit and user unit names instead of\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 321 (press h for help or q to quit)\u001b[27m\u001b[K"]
[68.64664400000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               the traditional syslog identifier. Useful when using templated instances,\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 322 (press h for help or q to quit)\u001b[27m\u001b[K"]
[68.72931, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               as it will include the arguments in the unit names.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 323 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 324 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--output-fields=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 325 (press h for help or q to quit)\u001b[27m\u001b[K"]
[68.863057, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[68.863185, "o", "           A comma separated list of the fields which should be included in the output.\u001b[m"]
[68.86359, "o", "\r\n"]
