[67.94146500000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 299 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mjson-pretty\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 300 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               formats entries as JSON data structures, but formats them in multiple lines\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 301 (press h for help or q to quit)\u001b[27m\u001b[K"]
[68.150327, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               in order to make them more readable by humans.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 302 (press h for help or q to quit)\u001b[27m\u001b[K"]
