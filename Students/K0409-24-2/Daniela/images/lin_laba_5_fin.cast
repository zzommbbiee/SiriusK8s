[228.05092600000015, "o", "#!/usr/bin/env bash"]
[228.05111700000012, "o", "\r\nset -euo pipefail\r\n\r\nLAB=\"/opt/break_lab\"\r\nmkdir -p \"$LAB\"\r\n\r\ncat > \"$LAB/script_server.sh\" <<'EOF'\r\n#!/usr/bin/env bash\r\nset -euo pipefail\r\necho \"script-server: \u0441\u0442\u0430\u0440\u0442 $(date -Is)\" >&2\r\nexit 0\r\nEOF\r\nchmod +x \"$LAB/script_server.sh\"\r\n\r\nUNIT=\"/etc/systemd/system/script-server.service\"\r\ncat > \"$UNIT\" <<EOF\r\n[Unit]\r\nDescription=Break Lab Script Server\r\nAfter=network.target\r\n\r\n[Service]\r\nType=simple\r\nExecStart=${LAB}/script_server.sh\r\nRestart=always\r\nRestartSec=2\r\nMemoryMax=64M\r\nCPUQuota=30%\r\n\r\n[Install]\r\nWantedBy=multi-user.target\r\nEOF\r\n\r\nsystemctl daemon-reload\r\nsystemctl enable --now script-server.service\r\n\r\necho \"\u0413\u043e\u0442\u043e\u0432\u043e!\"\r\necho \"\u0421\u0435\u0440\u0432\u0438\u0441 \u0441\u043e\u0437\u0434\u0430\u043d \u0438 \u0437\u0430\u043f\u0443\u0449\u0435\u043d (\u043d\u043e \u0431\u0443\u0434\u0435\u0442 \u043f\u0430\u0434\u0430\u0442\u044c)\"\r\necho \"\u041f\u0440\u043e\u0432\u0435\u0440\u043a\u0430: systemctl status script-server\"\r\necho \"\u041b\u043e\u0433\u0438: journalctl -u script-server -b --no-pager\"\r\n"]
