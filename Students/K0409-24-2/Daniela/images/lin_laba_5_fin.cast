[72.566317, "o", "\u001b[m"]
[72.566822, "o", "\r\n\u001b[7m Manual page journalctl(1) line 371 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--no-full\u001b[22m, \u001b[1m--full\u001b[22m, \u001b[1m-l\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 372 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Ellipsize fields when they do not fit in available columns. The default is to\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 373 (press h for help or q to quit)\u001b[27m\u001b[K"]
[72.579347, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[72.579953, "o", "           show full fields, allowing them to wrap or be truncated by the pager, if one is\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 374 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           used.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 375 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[72.58000700000001, "o", "\r\n\u001b[7m Manual page journalctl(1) line 376 (press h for help or q to quit)\u001b[27m\u001b[K"]
[72.608671, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[72.608789, "o", "           The old options \u001b[1m-l\u001b[22m/\u001b[1m--full \u001b[22mare not useful anymore, except to undo \u001b[1m--no-full\u001b[22m.\u001b[m\r\n"]
[72.60898, "o", "\u001b[7m Manual page journalctl(1) line 377 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[72.610361, "o", "\u001b[m"]
[72.610957, "o", "\r\n\u001b[7m Manual page journalctl(1) line 378 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-a\u001b[22m, \u001b[1m--all\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 379 (press h for help or q to quit)\u001b[27m\u001b[K"]
[72.644037, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show all fields in full, even if they include unprintable characters or are\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 380 (press h for help or q to quit)\u001b[27m\u001b[K"]
[72.644445, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           very long. By default, fields with unprintable characters are abbreviated as\u001b[m"]
[72.644706, "o", "\r\n\u001b[7m Manual page journalctl(1) line 381 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"blob data\". (Note that the pager may escape unprintable characters again.)\u001b[m\r\n"]
[72.644857, "o", "\u001b[7m Manual page journalctl(1) line 382 (press h for help or q to quit)\u001b[27m\u001b[K"]
[72.675416, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[72.67628, "o", "\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 383 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-f\u001b[22m, \u001b[1m--follow\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 384 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show only the most recent journal entries, and continuously print new entries\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 385 (press h for help or q to quit)\u001b[27m\u001b[K"]
