[67.111725, "o", "\r\n\u001b[7m Manual page journalctl(1) line 270 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[67.111898, "o", "           \u001b[1mverbose\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 271 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.130465, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[67.130699, "o", "               shows the full-structured entry items with all fields.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 272 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 273 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mexport\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 274 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.14581700000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               serializes the journal into a binary (but mostly text-based) stream\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 275 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.146172, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               suitable for backups and network transfer (see \u001b[34m\u001b[1mJournal Export Format\u001b[0m\u001b[1m\u001b[22m[2] for\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 276 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[67.146213, "o", "               more information). To import the binary stream back into native journald\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 277 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.406871, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               format use \u001b[1msystemd-journal-remote\u001b[22m(8).\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 278 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.407588, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 279 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mjson\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 280 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.417769, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               formats entries as JSON objects, separated by newline characters (see\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 281 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.418801, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[34m\u001b[1mJournal JSON Format\u001b[0m\u001b[1m\u001b[22m[3] for more information). Field values are generally\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 282 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               encoded as JSON strings, with three exceptions:\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 283 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.448824, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 284 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                1. Fields larger than 4096 bytes are encoded as \u001b[1mnull \u001b[22mvalues. (This may be\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 285 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   turned off by passing \u001b[1m--all\u001b[22m, but be aware that this may allocate overly\u001b[m"]
[67.449295, "o", "\r\n\u001b[7m Manual page journalctl(1) line 286 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.518541, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   long JSON objects.)\u001b[m"]
[67.518883, "o", "\r\n\u001b[7m Manual page journalctl(1) line 287 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[67.519373, "o", "\r\n\u001b[7m Manual page journalctl(1) line 288 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                2. Journal entries permit non-unique fields within the same log entry.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 289 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.662008, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[67.662233, "o", "                   JSON does not allow non-unique fields within objects. Due to this, if a\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 290 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   non-unique field is encountered a JSON array is used as field value,\u001b[m"]
[67.662621, "o", "\r\n\u001b[7m Manual page journalctl(1) line 291 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   listing all field values as elements.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 292 (press h for help or q to quit)\u001b[27m\u001b[K"]
[67.691339, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
