[73.475218, "o", "       \u001b[1m-q\u001b[22m, \u001b[1m--quiet\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 392 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Suppresses all informational messages (i.e. \"-- Journal begins at ...\", \"--\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 393 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Reboot --\"), any warning messages regarding inaccessible system journals when\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 394 (press h for help or q to quit)\u001b[27m\u001b[K"]
