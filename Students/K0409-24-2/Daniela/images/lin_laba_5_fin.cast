[150.90650100000005, "o", "\u001b[1;1H\u001b[34m#!/usr/bin/env bash\u001b[m\r\n\u001b[38;5;130mset\u001b[m\u001b[36m \u001b[m\u001b[35m-euo\u001b[m\u001b[36m pipefail\u001b[m\u001b[2;18H\u001b[K\u001b[3;1H\u001b[K\u001b[4;1H\u001b[36mLAB\u001b[m=\u001b[38;5;130m\"\u001b[m\u001b[31m/opt/break_lab\u001b[m\u001b[38;5;130m\"\r\nmkdir\u001b[m \u001b[35m-p\u001b[m \u001b[38;5;130m\"\u001b[m\u001b[35m$LAB\u001b[m\u001b[38;5;130m\"\u001b[m\r\n\r\ncat \u001b[38;5;130m>\u001b[m \u001b[38;5;130m\"\u001b[m\u001b[35m$LAB\u001b[m\u001b[31m/script_server.sh\u001b[m\u001b[38;5;130m\"\u001b[m \u001b[38;5;130m<<'EOF'\u001b[m\r\n\u001b[31m#!/usr/bin/env bash\r\nset -euo pipefail\r\necho \"script-server: \u0441\u001b[10;23H\u0442\u001b[10;24H\u0430\u001b[10;25H\u0440\u001b[10;26H\u0442\u001b[10;27H $(date -Is)\" >&2\r\nexit 1\u001b[m\r\n\u001b[38;5;130mEOF\r\nchmod\u001b[m \u001b[35m+x\u001b[m \u001b[38;5;130m\"\u001b[m\u001b[35m$LAB\u001b[m\u001b[31m/script_server.sh\u001b[m\u001b[38;5;130m\"\u001b[m\r\n\r\n\u001b[36mUNIT\u001b[m=\u001b[38;5;130m\"\u001b[m\u001b[31m/etc/systemd/system/script-server.service\u001b[m\u001b[38;5;130m\"\u001b[m\r\ncat \u001b[38;5;130m>\u001b[m \u001b[38;5;130m\"\u001b[m\u001b[35m$UNIT\u001b[m\u001b[38;5;130m\"\u001b[m \u001b[38;5;130m<<EOF\u001b[m\r\n\u001b[31m[Unit]\r\nDescription=Break Lab Script Server\r\nAfter=network.target\r\n\r\n[Service]\r\nType=simple\r\nExecStart=\u001b[m\u001b[35m${LAB}\u001b[m\u001b[31m/script_server.sh\u001b[m\u001b[24;76H1,1\u001b[8C\u041d\u001b[24;88H\u0430\u001b[24;89H\u0447\u001b[24;90H\u0430\u001b[24;91H\u043b\u001b[24;92H\u043e\u001b[1;1H\u001b[?25h\u001b[?4m"]
