[69.101917, "o", "\u001b[7m Manual page journalctl(1) line 334 (press h for help or q to quit)\u001b[27m\u001b[K"]
[69.13232500000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"all\" to disable line limiting. The default value is 10 if no argument is\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 335 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           given.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 336 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 337 (press h for help or q to quit)\u001b[27m\u001b[K"]
[69.167073, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           When used with \u001b[1m--grep=\u001b[22m, \u001b[1m--reverse \u001b[22mis implied.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 338 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 339 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-r\u001b[22m, \u001b[1m--reverse\u001b[0m\u001b[m"]
[69.167164, "o", "\r\n\u001b[7m Manual page journalctl(1) line 340 (press h for help or q to quit)\u001b[27m\u001b[K"]
[69.354839, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Reverse output so that the newest entries are displayed first.\u001b[m"]
