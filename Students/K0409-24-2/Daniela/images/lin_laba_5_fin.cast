[73.506494, "o", "           run as a normal user.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 395 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 396 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[1mPAGER CONTROL OPTIONS\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 397 (press h for help or q to quit)\u001b[27m\u001b[K"]
