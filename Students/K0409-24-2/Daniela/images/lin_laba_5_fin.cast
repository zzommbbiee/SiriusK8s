[71.22826500000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[71.228644, "o", "       \u001b[1m-x\u001b[22m, \u001b[1m--catalog\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 353 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Augment log lines with explanation texts from the message catalog. This will\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 354 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           add explanatory help texts to log messages in the output where this is\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 355 (press h for help or q to quit)\u001b[27m\u001b[K"]
[71.260835, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[71.26128200000001, "o", "           available. These short help texts will explain the context of an error or log\u001b[m"]
[71.261494, "o", "\r\n\u001b[7m Manual page journalctl(1) line 356 (press h for help or q to quit)\u001b[27m\u001b[K"]
[71.261741, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           event, possible solutions, as well as pointers to support forums, developer\u001b[m"]
[71.261842, "o", "\r\n\u001b[7m Manual page journalctl(1) line 357 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[71.26199100000001, "o", "           documentation, and any other relevant manuals. Note that help texts are not\u001b[m"]
[71.262057, "o", "\r\n\u001b[7m Manual page journalctl(1) line 358 (press h for help or q to quit)\u001b[27m\u001b[K"]
[71.587275, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[71.588282, "o", "           available for all messages, but only for selected ones. For more information on\u001b[m"]
[71.588785, "o", "\r\n"]
[71.588924, "o", "\u001b[7m Manual page journalctl(1) line 359 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[71.58919900000001, "o", "           the message catalog, please refer to the \u001b[34m\u001b[1mMessage Catalog Developer\u001b[0m\u001b[m"]
