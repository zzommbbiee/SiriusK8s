[76.973054, "o", "\r\n\u001b[7m Manual page journalctl(1) line 411 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       below:\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 412 (press h for help or q to quit)\u001b[27m\u001b[K"]
[79.973054, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 413 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--interval=\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 414 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Specifies the change interval for the sealing key when generating an FSS key\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 415 (press h for help or q to quit)\u001b[27m\u001b[K"]
