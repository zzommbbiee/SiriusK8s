[68.377567, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               character (0x0A), in accordance with \u001b[34m\u001b[1mJavaScript Object Notation (JSON) Text\u001b[0m\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 311 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[1m\u001b[34mSequences\u001b[0m\u001b[1m\u001b[22m[5] (\"application/json-seq\").\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 312 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 313 (press h for help or q to quit)\u001b[27m\u001b[K"]
