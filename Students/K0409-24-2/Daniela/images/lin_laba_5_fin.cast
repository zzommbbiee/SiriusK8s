[68.901577, "o", "           \"__MONOTONIC_TIMESTAMP\", and \"_BOOT_ID\" fields are always printed.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 330 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 331 (press h for help or q to quit)\u001b[27m\u001b[K"]
