[71.630404, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[71.63082, "o", "\r\n\u001b[7m Manual page journalctl(1) line 362 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Note: when attaching \u001b[1mjournalctl \u001b[22moutput to bug reports, please do \u001b[4mnot\u001b[24m use \u001b[1m-x\u001b[22m.\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 363 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page journalctl(1) line 364 (press h for help or q to quit)\u001b[27m\u001b[K"]
[72.49378300000001, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--no-hostname\u001b[0m\u001b[m"]
