[353.516242, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               some networks may require credentials during activation. You can give\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 344 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[353.51658, "o", "               these credentials using this option. Each line of the file should\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 345 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               contain one password in the form:\u001b[m"]
[353.516797, "o", "\r\n\u001b[7m Manual page nmcli(1) line 346 (press h for help or q to quit)\u001b[27m\u001b[K"]
[353.543688, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
