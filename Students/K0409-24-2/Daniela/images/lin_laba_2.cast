[370.176233, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           scripts. This option controls, for example, whether you will be prompted\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 11 (press h for help or q to quit)\u001b[27m\u001b[K"]
[370.178213, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           for a password if it is required for connecting to a network.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 12 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 13 (press h for help or q to quit)\u001b[27m\u001b[K"]
[371.664428, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[371.66495, "o", "       \u001b[1m-c \u001b[22m| \u001b[1m--colors \u001b[22m{yes | no | auto}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 14 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option controls color output (using terminal escape sequences).  yes\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 15 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           enables colors, no disables them, auto only produces colors when standard\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 16 (press h for help or q to quit)\u001b[27m\u001b[K"]
[371.671716, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[371.67215, "o", "           output is directed to a terminal. The default value is auto.\u001b[m\r\n"]
