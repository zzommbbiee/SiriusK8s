[354.864586, "o", "\u001b[H\u001bM       Query NetworkManager networking status, enable and disable networking.\u001b[m"]
[354.865899, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 207 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 206 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.866235, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mnmcli networking \u001b[22m{\u001b[1mon \u001b[22m| \u001b[1moff \u001b[22m| \u001b[1mconnectivity\u001b[22m} [\u001b[4mARGUMENTS\u001b[24m...]\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 205 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.876786, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mNETWORKING CONTROL COMMANDS\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 204 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 203 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           about signals.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 202 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           identical to sending a SIGHUP. See \u001b[1mNetworkManager\u001b[22m(8) for more details\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 201 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           With no flags, everything that is supported is reloaded, which is\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 200 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 199 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.890162, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               resolution.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 198 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               restart the DNS plugin. This action shortly interrupts name\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 197 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               /etc/NetworkManager/dnsmasq.d. If you edit those files, you can\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 196 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               plugin, which uses additional configuration in\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 195 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               Restart the DNS plugin. This is for example useful when using dnsmasq\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 194 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mdns-full"]
[354.89022, "o", "\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 193 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.896358, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.896549, "o", "\u001b[H\u001bM\u001b[m"]
[354.896629, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 192 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               signal to the NetworkManager process.\u001b[m"]
[354.897009, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 191 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               /etc/resolv.conf anew. This is equivalent to sending the SIGUSR1\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 190 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.928571, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.929332, "o", "\u001b[H\u001bM               Update DNS configuration, which usually involves writing\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 189 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mdns-rc\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 188 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 187 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.943411, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.943856, "o", "\u001b[H\u001bM               \u001b[1mconnection reload \u001b[22minstead.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 186 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.943893, "o", "\u001b[H\u001bM               does not include connections, which can be reloaded through \u001b[1mnmcli\u001b[0m\u001b[m"]
[354.94417, "o", "\r\n"]
[354.944349, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 185 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               Reload the NetworkManager.conf configuration from disk. Note that this\u001b[m"]
[354.944466, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 184 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.96053, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
