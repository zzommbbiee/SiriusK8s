[371.694433, "o", "\r\n\u001b[7m Manual page nmcli(1) line 20 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           supported by \u001b[1mnmcli\u001b[22m.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 21 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[371.694479, "o", "\u001b[m"]
[371.694502, "o", "\r\n\u001b[7m Manual page nmcli(1) line 22 (press h for help or q to quit)\u001b[27m\u001b[K"]
[371.71771, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If the environment variable NO_COLOR is set (to any non-empty value), then\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 23 (press h for help or q to quit)\u001b[27m\u001b[K"]
[371.718016, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           coloring is disabled with mode \"auto\". If the environment variable\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 24 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           CLICOLOR_FORCE is set (to any non-empty value), then coloring is enabled\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 25 (press h for help or q to quit)\u001b[27m\u001b[K"]
[371.722594, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           with mode \"auto\". Explicitly enabling coloring overrides the environment\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 26 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           variable.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 27 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[371.743913, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--complete-args\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Instead of conducting the desired action, \u001b[1mnmcli \u001b[22mwill list possible\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           completions for the last argument. This is useful to implement argument\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[371.772407, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           completion in shell.\u001b[m"]
[371.772722, "o", "\r\n\u001b[7m Manual page nmcli(1) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 33 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The exit status will indicate success or return a code 65 to indicate the\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
[372.296628, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[372.29759, "o", "\u001b[H\u001bM           scripts. This option controls, for example, whether you will be prompted\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 33 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           arguments, so do not use this option for non-interactive purposes like\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           When using this option \u001b[1mnmcli \u001b[22mwill stop and ask for any missing required\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[372.338805, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1m-a \u001b[22m| \u001b[1m--ask\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mOPTIONS\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K"]
[372.339572, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 28 (press h for help or q to quit)\u001b[27m\u001b[K"]
[374.734835, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--complete-args\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 29 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Instead of conducting the desired action, \u001b[1mnmcli \u001b[22mwill list possible\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 30 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[374.735091, "o", "           completions for the last argument. This is useful to implement argument\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 31 (press h for help or q to quit)\u001b[27m\u001b[K"]
[375.457609, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           completion in shell.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 32 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 33 (press h for help or q to quit)\u001b[27m\u001b[K"]
[375.457848, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The exit status will indicate success or return a code 65 to indicate the\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 34 (press h for help or q to quit)\u001b[27m\u001b[K"]
[375.478585, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[375.478832, "o", "           last argument is a file name.\u001b[m"]
[375.479292, "o", "\r\n\u001b[7m Manual page nmcli(1) line 35 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 36 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           NetworkManager ships with command completion support for GNU Bash.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 37 (press h for help or q to quit)\u001b[27m\u001b[K"]
[375.52312, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[375.52344, "o", "\u001b[m"]
[375.52471, "o", "\r\n\u001b[7m Manual page nmcli(1) line 38 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-e \u001b[22m| \u001b[1m--escape \u001b[22m{yes | no}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 39 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Whether to escape : and \\ characters in terse tabular mode. The escape\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 40 (press h for help or q to quit)\u001b[27m\u001b[K"]
[375.556561, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[375.557505, "o", "           character is \\.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 41 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 42 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If omitted, default is yes.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 43 (press h for help or q to quit)\u001b[27m\u001b[K"]
[376.272636, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 44 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-f \u001b[22m| \u001b[1m--fields \u001b[22m{\u001b[4mfield1\u001b[24m,\u001b[4mfield2\u001b[24m... | all | common}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 45 (press h for help or q to quit)\u001b[27m\u001b[K"]
[376.27423, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option is used to specify what fields (column names) should be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 46 (press h for help or q to quit)\u001b[27m\u001b[K"]
[376.293, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[376.293179, "o", "           printed. Valid field names differ for specific commands. List available\u001b[m"]
[376.294175, "o", "\r\n"]
[376.294746, "o", "\u001b[7m Manual page nmcli(1) line 47 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[376.294825, "o", "           fields by providing an invalid value to the \u001b[1m--fields \u001b[22moption.  all is used\u001b[m"]
[376.295229, "o", "\r\n\u001b[7m Manual page nmcli(1) line 48 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           to print all valid field values of the command.  common is used to print\u001b[m"]
[376.295314, "o", "\r\n\u001b[7m Manual page nmcli(1) line 49 (press h for help or q to quit)\u001b[27m\u001b[K"]
[376.322262, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[376.322765, "o", "           common field values of the command.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 50 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[376.322802, "o", "\u001b[m"]
[376.324702, "o", "\r\n\u001b[7m Manual page nmcli(1) line 51 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If omitted, default is common.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 52 (press h for help or q to quit)\u001b[27m\u001b[K"]
[376.338806, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 53 (press h for help or q to quit)\u001b[27m\u001b[K"]
[376.339965, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-g \u001b[22m| \u001b[1m--get-values \u001b[22m{\u001b[4mfield1\u001b[24m,\u001b[4mfield2\u001b[24m... | all | common}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 54 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option is used to print values from specific fields. It is basically\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 55 (press h for help or q to quit)\u001b[27m\u001b[K"]
[376.366197, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           a shortcut for --mode tabular --terse --fields and is a convenient way to\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 56 (press h for help or q to quit)\u001b[27m\u001b[K"]
[376.36643, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           retrieve values for particular fields. The values are printed one per line\u001b[m"]
[376.366495, "o", "\r\n"]
[376.367201, "o", "\u001b[7m Manual page nmcli(1) line 57 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[376.367347, "o", "           without headers.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 58 (press h for help or q to quit)\u001b[27m\u001b[K"]
[377.016545, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[377.017062, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 59 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           If a section is specified instead of a field, the section name will be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 60 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           printed followed by colon separated values of the fields belonging to that\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 61 (press h for help or q to quit)\u001b[27m\u001b[K"]
[377.037748, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           section, all on the same line.\u001b[m"]
[377.038053, "o", "\r\n\u001b[7m Manual page nmcli(1) line 62 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 63 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-h \u001b[22m| \u001b[1m--help\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 64 (press h for help or q to quit)\u001b[27m\u001b[K"]
[377.06737, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[377.068634, "o", "           Print help information.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 65 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 66 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-m \u001b[22m| \u001b[1m--mode \u001b[22m{tabular | multiline}\u001b[m"]
[377.070647, "o", "\r\n\u001b[7m Manual page nmcli(1) line 67 (press h for help or q to quit)\u001b[27m\u001b[K"]
[377.089549, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Switch between tabular and multiline output:\u001b[m"]
[377.090613, "o", "\r\n\u001b[7m Manual page nmcli(1) line 68 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 69 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           tabular\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 70 (press h for help or q to quit)\u001b[27m\u001b[K"]
[378.150254, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Output is a table where each line describes a single entry. Columns\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 71 (press h for help or q to quit)\u001b[27m\u001b[K"]
[378.150606, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               define particular properties of the entry.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 72 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 73 (press h for help or q to quit)\u001b[27m\u001b[K"]
[378.182097, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           multiline\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 74 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Each entry comprises multiple lines, each property on its own line.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 75 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               The values are prefixed with the property name.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 76 (press h for help or q to quit)\u001b[27m\u001b[K"]
