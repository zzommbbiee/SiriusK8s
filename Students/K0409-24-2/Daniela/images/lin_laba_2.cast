[339.320986, "o", "\r\n\u001b[7m Manual page nmcli(1) line 130 (press h for help or q to quit)\u001b[27m\u001b[K"]
[339.352024, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mhostname \u001b[22m[\u001b[4mhostname\u001b[24m]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 131 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Get and change system hostname. With no arguments, this prints currently\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 132 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           configured hostname. When you pass a hostname, it will be handed over to\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 133 (press h for help or q to quit)\u001b[27m\u001b[K"]
[339.389949, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[339.390662, "o", "           NetworkManager to be set as a new system hostname.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 134 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[339.391289, "o", "\u001b[m"]
[339.392129, "o", "\r\n\u001b[7m Manual page nmcli(1) line 135 (press h for help or q to quit)\u001b[27m\u001b[K"]
[339.392385, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Note that the term \"system\" hostname may also be referred to as\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 136 (press h for help or q to quit)\u001b[27m\u001b[K"]
[339.466513, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \"persistent\" or \"static\" by other programs or tools. The hostname is\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 137 (press h for help or q to quit)\u001b[27m\u001b[K"]
[339.467818, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           stored in /etc/hostname file in most distributions. For example,\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 138 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           systemd-hostnamed service uses the term \"static\" hostname and it only\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 139 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.435761, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           reads the /etc/hostname file when it starts.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 140 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.436577, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.437293, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 141 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.437357, "o", "       \u001b[1mpermissions\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 142 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.507661, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.507751, "o", "           Show the permissions a caller has for various authenticated operations\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 143 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.50792, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.508018, "o", "           that NetworkManager provides, like enable and disable networking, changing\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 144 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.509142, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.509308, "o", "           Wi-Fi and WWAN state, modifying connections, etc.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 145 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.578739, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.579005, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 146 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.57931, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.583148, "o", "       \u001b[1mlogging \u001b[22m[\u001b[1mlevel \u001b[4m\u001b[22mlevel\u001b[24m] [\u001b[1mdomains \u001b[4m\u001b[22mdomains\u001b[24m...]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 147 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Get and change NetworkManager logging level and domains. Without any\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 148 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.953757, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           argument current logging level and domains are shown. In order to change\u001b[m"]
[341.953848, "o", "\r\n\u001b[7m Manual page nmcli(1) line 149 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           logging state, provide \u001b[1mlevel \u001b[22mand, or, \u001b[1mdomain \u001b[22mparameters. See\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 150 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mNetworkManager.conf\u001b[22m(5) for available level and domain values.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 151 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.974464, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.974668, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 152 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[341.974719, "o", "       \u001b[1mreload \u001b[22m[\u001b[4mflags\u001b[24m...]\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 153 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Reload NetworkManager's configuration and perform certain updates, like\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 154 (press h for help or q to quit)\u001b[27m\u001b[K"]
[341.995952, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           flushing caches or rewriting external state to disk. This is similar to\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 155 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           sending SIGHUP to NetworkManager but it allows for more fine-grained\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 156 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           control over what to reload through the flags argument. It also allows\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 157 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.01699, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           non-root access via PolicyKit and contrary to signals it is synchronous.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 158 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Available flags are:\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 159 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 160 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.040254, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mconf\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 161 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Reload the NetworkManager.conf configuration from disk. Note that this\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 162 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               does not include connections, which can be reloaded through \u001b[1mnmcli\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 163 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.066887, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               \u001b[1mconnection reload \u001b[22minstead.\u001b[m"]
[342.067249, "o", "\r\n\u001b[7m Manual page nmcli(1) line 164 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 165 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mdns-rc\u001b[0m\u001b[m"]
[342.067313, "o", "\r\n\u001b[7m Manual page nmcli(1) line 166 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.564202, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Update DNS configuration, which usually involves writing\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 167 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               /etc/resolv.conf anew. This is equivalent to sending the SIGUSR1\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 168 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               signal to the NetworkManager process.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 169 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.573984, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[342.57422, "o", "\u001b[m\r\n"]
[342.574246, "o", "\u001b[7m Manual page nmcli(1) line 170 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.574282, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[342.574649, "o", "           \u001b[1mdns-full\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 171 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               Restart the DNS plugin. This is for example useful when using dnsmasq\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 172 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.597677, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               plugin, which uses additional configuration in\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 173 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               /etc/NetworkManager/dnsmasq.d. If you edit those files, you can\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 174 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               restart the DNS plugin. This action shortly interrupts name\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 175 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.614689, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               resolution.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 176 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[342.616262, "o", "\r\n\u001b[7m Manual page nmcli(1) line 177 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.616352, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           With no flags, everything that is supported is reloaded, which is\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 178 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.640857, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           identical to sending a SIGHUP. See \u001b[1mNetworkManager\u001b[22m(8) for more details\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 179 (press h for help or q to quit)\u001b[27m\u001b[K"]
[342.641641, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           about signals.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 180 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 181 (press h for help or q to quit)\u001b[27m\u001b[K"]
