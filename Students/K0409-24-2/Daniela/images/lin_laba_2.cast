[343.659646, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[343.659802, "o", "       Query NetworkManager networking status, enable and disable networking.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 185 (press h for help or q to quit)\u001b[27m\u001b[K"]
[343.661235, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 186 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mon\u001b[22m, \u001b[1moff\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 187 (press h for help or q to quit)\u001b[27m\u001b[K"]
[343.69023, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Enable or disable networking control by NetworkManager. All interfaces\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 188 (press h for help or q to quit)\u001b[27m\u001b[K"]
[343.690606, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           managed by NetworkManager are deactivated when networking is disabled.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 189 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 190 (press h for help or q to quit)\u001b[27m\u001b[K"]
[343.733682, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1mconnectivity \u001b[22m[check]\u001b[m"]
[343.733767, "o", "\r\n\u001b[7m Manual page nmcli(1) line 191 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Get network connectivity state. The optional \u001b[1mcheck \u001b[22margument tells\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 192 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[343.736345, "o", "           NetworkManager to re-check the connectivity, else the most recent known\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 193 (press h for help or q to quit)\u001b[27m\u001b[K"]
[343.866, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           connectivity state is displayed without re-checking.\u001b[m"]
