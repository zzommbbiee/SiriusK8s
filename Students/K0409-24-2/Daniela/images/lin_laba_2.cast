[354.960808, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 182 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.961092, "o", "\u001b[H\u001bM           Available flags are:\u001b[m"]
[354.961138, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 181 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.976645, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.976871, "o", "\u001b[H\u001bM           non-root access via PolicyKit and contrary to signals it is synchronous.\u001b[m"]
[354.977138, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 180 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           control over what to reload through the flags argument. It also allows\u001b[m"]
[354.97717, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 179 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           sending SIGHUP to NetworkManager but it allows for more fine-grained\u001b[m"]
[354.977782, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 178 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.991844, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.992444, "o", "\u001b[H\u001bM           flushing caches or rewriting external state to disk. This is similar to\u001b[m"]
[354.992509, "o", "\r\n"]
