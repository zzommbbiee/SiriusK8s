[353.480199, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 338 (press h for help or q to quit)\u001b[27m\u001b[K"]
[353.480647, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1map\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 339 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               BSSID of the AP which the command should connect to (for Wi-Fi\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 340 (press h for help or q to quit)\u001b[27m\u001b[K"]
