[335.881199, "o", "\r\n\u001b[7m Manual page nmcli(1) line 107 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Show \u001b[1mnmcli \u001b[22mversion.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 108 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 109 (press h for help or q to quit)\u001b[27m\u001b[K"]
[336.976253, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m-w \u001b[22m| \u001b[1m--wait \u001b[4m\u001b[22mseconds\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 110 (press h for help or q to quit)\u001b[27m\u001b[K"]
[336.976991, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           This option sets a timeout period for which \u001b[1mnmcli \u001b[22mwill wait for\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 111 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           NetworkManager to finish operations. It is especially useful for commands\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 112 (press h for help or q to quit)\u001b[27m\u001b[K"]
[337.004578, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           that may take a longer time to complete, e.g. connection activation.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 113 (press h for help or q to quit)\u001b[27m\u001b[K"]
[337.004913, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 114 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Specifying a value of 0 instructs \u001b[1mnmcli \u001b[22mnot to wait but to exit\u001b[m"]
