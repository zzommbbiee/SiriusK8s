[337.019687, "o", "\r\n\u001b[7m Manual page nmcli(1) line 116 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           executed command.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 117 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 118 (press h for help or q to quit)\u001b[27m\u001b[K"]
