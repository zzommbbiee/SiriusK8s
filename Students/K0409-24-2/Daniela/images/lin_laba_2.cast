[354.662397, "o", "\u001b[H\u001bM           arguments are supplied, mobile broadband status is printed; \u001b[1mon \u001b[22menables\u001b[m"]
[354.663026, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 249 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Show or set status of WWAN (mobile broadband) in NetworkManager. If no\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 248 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mwwan \u001b[22m[on | off]\u001b[m"]
