[354.245236, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.24551, "o", "\u001b[H\u001bM           If \u001b[1m--wait \u001b[22moption is not specified, the default timeout will be 90 seconds.\u001b[m"]
[354.245571, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 351 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m"]
[354.245933, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 350 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.245974, "o", "\u001b[H\u001bM           what particular AP should be used in case of a Wi-Fi connection.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 349 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           option specifies the device of the base connection. The \u001b[1map \u001b[22moption specify\u001b[m"]
[354.246207, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 348 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           connection for the given \u001b[1mifname\u001b[22m. In case of a VPN connection, the \u001b[1mifname\u001b[0m\u001b[m"]
[354.246233, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 347 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.246354, "o", "\u001b[H\u001bM           an \u001b[1mifname \u001b[22mis required, and NetworkManager will activate the best available\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 346 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.252474, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mifname \u001b[22moption with interface name should be given. If the \u001b[4mID\u001b[24m is not given\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 345 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           When requiring a particular device to activate the connection on, the\u001b[m"]
[354.252736, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 344 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.252815, "o", "\u001b[H\u001bM           D-Bus path. If \u001b[4mID\u001b[24m is ambiguous, a keyword \u001b[1mid\u001b[22m, \u001b[1muuid \u001b[22mor \u001b[1mpath \u001b[22mcan be used.\u001b[m"]
[354.252875, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 343 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.267837, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Activate a connection. The connection is identified by its name, UUID or\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 342 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.268154, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.2708, "o", "\u001b[H\u001bM       \u001b[1mup \u001b[22m[\u001b[1mid \u001b[22m| \u001b[1muuid \u001b[22m| \u001b[1mpath\u001b[22m] \u001b[4mID\u001b[24m [\u001b[1mifname \u001b[4m\u001b[22mifname\u001b[24m] [\u001b[1map \u001b[4m\u001b[22mBSSID\u001b[24m] [\u001b[1mpasswd-file \u001b[4m\u001b[22mfile\u001b[24m]\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 341 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 340 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mnmcli connection show\u001b[22m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 339 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           When no command is given to the \u001b[1mnmcli connection\u001b[22m, the default action is\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 338 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 337 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.282153, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           page. For active data use GENERAL, IP4, DHCP4, IP6, DHCP6, VPN.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 336 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.282867, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.283212, "o", "\u001b[H\u001bM           setting and property names as described in \u001b[1mnm-settings-nmcli\u001b[22m(5) manual\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 335 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           You can also specify particular fields. For static configuration, use\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 334 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 333 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               only shows active connection data (when the profile is active).\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 332 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mactive\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 331 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.29464, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.295356, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 330 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.295745, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               only shows static profile configuration.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 329 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.295887, "o", "\u001b[H\u001bM           \u001b[1mprofile\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 328 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.296765, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 327 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.29789, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           the following values:\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 326 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.298524, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           It is possible to filter the output using the global \u001b[1m--fields \u001b[22moption. Use\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 325 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.308491, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.309455, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 324 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.309501, "o", "\u001b[H\u001bM               /org/freedesktop/NetworkManager/ActiveConnection/\u001b[4mnum\u001b[24m or just \u001b[4mnum\u001b[24m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 323 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               the \u001b[4mID\u001b[24m denotes a D-Bus active connection path in the format of\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 322 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.336049, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.336119, "o", "\u001b[H\u001bM           \u001b[1mapath\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 321 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.336899, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 320 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               /org/freedesktop/NetworkManager/Settings/\u001b[4mnum\u001b[24m or just \u001b[4mnum\u001b[24m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 319 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.350964, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.351412, "o", "\u001b[H\u001bM               the \u001b[4mID\u001b[24m denotes a D-Bus static connection path in the format of\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 318 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.351848, "o", "\u001b[H\u001bM           \u001b[1mpath\u001b[0m\u001b[m"]
[354.353101, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 317 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 316 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.367015, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.367444, "o", "\u001b[H\u001bM               the \u001b[4mID\u001b[24m denotes a connection UUID.\u001b[m"]
[354.367589, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 315 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.367763, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.368029, "o", "\u001b[H\u001bM           \u001b[1muuid\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 314 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.369915, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 313 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.381499, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM               the \u001b[4mID\u001b[24m denotes a connection name.\u001b[m"]
[354.381968, "o", "\r\n"]
[354.382334, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 312 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.38384, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.384066, "o", "\u001b[H\u001bM           \u001b[1mid\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 311 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 310 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.39984, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[4mID\u001b[24m-specifying keywords are:\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 309 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.400505, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mid\u001b[22m, \u001b[1muuid\u001b[22m, \u001b[1mpath \u001b[22mand \u001b[1mapath \u001b[22mkeywords can be used if \u001b[4mID\u001b[24m is ambiguous. Optional\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 308 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n"]
[354.400667, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 307 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.413931, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.4153, "o", "\u001b[H\u001bM           profile.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 306 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.415891, "o", "\u001b[H\u001bM           global \u001b[1m--show-secrets \u001b[22moption to display secrets associated with the\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 305 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           option is specified, only the active profiles are taken into account. Use\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 304 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.428993, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           configuration and active connection data are displayed. When \u001b[1m--active\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 303 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Show details for specified connections. By default, both static\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 302 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mshow \u001b[22m[\u001b[1m--active\u001b[22m] [\u001b[1mid \u001b[22m| \u001b[1muuid \u001b[22m| \u001b[1mpath \u001b[22m| \u001b[1mapath\u001b[22m] \u001b[4mID\u001b[24m...\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 301 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.445122, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 300 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           --order -a:na).\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 299 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.445373, "o", "\u001b[H\u001bM           reverse (descending) order. The category names can be abbreviated (e.g.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 298 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.45862, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.458902, "o", "\u001b[H\u001bM           means sorting in ascending order (alphabetically or in numbers), - means\u001b[m"]
[354.459404, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 297 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.459482, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.459834, "o", "\u001b[H\u001bM           sorting order is equivalent to --order active:name:path.  + or no prefix\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 296 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.459885, "o", "\u001b[H\u001bM           order category, an additional category can be specified. The default\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 295 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.474722, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.475755, "o", "\u001b[H\u001bM           (type) or D-Bus path (path). If connections are equal according to a sort\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 294 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           connections can be ordered by active status (active), name (name), type\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 293 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           The \u001b[1m--order \u001b[22moption can be used to get custom ordering of connections. The\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 292 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.489301, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.489671, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 291 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           active profiles are shown.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 290 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           all profiles are listed. When \u001b[1m--active \u001b[22moption is specified, only the\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 289 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.506815, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           active if a device is using that connection profile. Without a parameter,\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 288 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.506896, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           List in-memory and on-disk connection profiles, some of which may also be\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 287 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mshow \u001b[22m[\u001b[1m--active\u001b[22m] [\u001b[1m--order \u001b[22m[+-]\u001b[4mcategory\u001b[24m:...]\u001b[m\r\n"]
[354.506923, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 286 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.523164, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 285 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mnmcli con up testing\u001b[22m.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 284 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mcon up default \u001b[22m, and when connected to the static network the user would run\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 283 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.540427, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       testing). When connected to the DHCP-enabled network the user would run \u001b[1mnmcli\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 282 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.54122, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.541286, "o", "\u001b[H\u001bM       DHCP (called default) and one with the static addressing details (called\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 281 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.541311, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.541335, "o", "\u001b[H\u001bM       settings can be saved as two connections which both apply to eth0, one for\u001b[m\r\n"]
[354.541357, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 280 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.554354, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.554711, "o", "\u001b[H\u001bM       Instead of manually reconfiguring eth0 each time the network is changed, the\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 279 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.555162, "o", "\u001b[H\u001bM       sometimes connected to a testing network which uses static IP addressing.\u001b[m"]
[354.556293, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 278 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       Consider a machine which is usually connected to a DHCP-enabled network, but\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 277 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.565575, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.565635, "o", "\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 276 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.565653, "o", "\u001b[H\u001bM       used to allow quick switching between different networks and configurations.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 275 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.566363, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.566402, "o", "\u001b[H\u001bM       active on that device at any given time. The additional connections can be\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 274 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.576842, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       be multiple connections that apply to a device, but only one of them can be\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 273 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.577417, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       that connection's configuration to create or connect to a network. There may\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 272 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       create or connect to a network. A connection is \"active\" when a device uses\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 271 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.587148, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.587282, "o", "\u001b[H\u001bM       collections of data (Layer2 details, IP addressing, etc.) that describe how to\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 270 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       NetworkManager stores all network configuration as \"connections\", which are\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 269 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.5875, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 268 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.587528, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM                        [\u001b[4mARGUMENTS\u001b[24m...]\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 267 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM                        \u001b[1mmonitor \u001b[22m| \u001b[1mreload \u001b[22m| \u001b[1mload \u001b[22m| \u001b[1mimport \u001b[22m| \u001b[1mexport \u001b[22m| \u001b[1mmigrate\u001b[22m}\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 266 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mnmcli connection \u001b[22m{\u001b[1mshow \u001b[22m| \u001b[1mup \u001b[22m| \u001b[1mdown \u001b[22m| \u001b[1mmodify \u001b[22m| \u001b[1madd \u001b[22m| \u001b[1medit \u001b[22m| \u001b[1mclone \u001b[22m| \u001b[1mdelete \u001b[22m|\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 265 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.599813, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[1mCONNECTION MANAGEMENT COMMANDS\u001b[0m\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 264 (press h for help or q to quit)\u001b[27m\u001b[K"]
[354.600098, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM\u001b[m\r\n"]
