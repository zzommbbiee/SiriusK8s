[335.785749, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       \u001b[1m--offline\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 99 (press h for help or q to quit)\u001b[27m\u001b[K"]
[335.787793, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           Work without a daemon. Makes \u001b[1mconnection add \u001b[22mand \u001b[1mconnection modify \u001b[22mcommands\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 100 (press h for help or q to quit)\u001b[27m\u001b[K"]
[335.81406, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           accept and produce connection data via standard input/output. Ordinarily,\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 101 (press h for help or q to quit)\u001b[27m\u001b[K"]
[335.815813, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           nmcli would communicate with the NetworkManager service.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 102 (press h for help or q to quit)\u001b[27m\u001b[K"]
[335.816108, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 103 (press h for help or q to quit)\u001b[27m\u001b[K"]
[335.828859, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           The connection data format (keyfile) is described in \u001b[1mnm-settings-\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 104 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mkeyfile\u001b[22m(5) manual.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 105 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 106 (press h for help or q to quit)\u001b[27m\u001b[K"]
