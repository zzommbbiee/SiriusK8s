[355.010018, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           \u001b[1mNetworkManager.conf\u001b[22m(5) for available level and domain values.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 173 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           logging state, provide \u001b[1mlevel \u001b[22mand, or, \u001b[1mdomain \u001b[22mparameters. See\u001b[m\r\n"]
[355.010243, "o", "\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 172 (press h for help or q to quit)\u001b[27m\u001b[K"]
[355.024329, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           argument current logging level and domains are shown. In order to change\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 171 (press h for help or q to quit)\u001b[27m\u001b[K"]
[355.024894, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           Get and change NetworkManager logging level and domains. Without any\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 170 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       \u001b[1mlogging \u001b[22m[\u001b[1mlevel \u001b[4m\u001b[22mlevel\u001b[24m] [\u001b[1mdomains \u001b[4m\u001b[22mdomains\u001b[24m...]\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 169 (press h for help or q to quit)\u001b[27m\u001b[K"]
[355.051063, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
