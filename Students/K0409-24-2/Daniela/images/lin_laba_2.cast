[360.662445, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 16 (press h for help or q to quit)\u001b[27m\u001b[K"]
[360.681495, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM       device status. See \u001b[1mnmcli-examples\u001b[22m(7) for ready to run nmcli examples.\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 15 (press h for help or q to quit)\u001b[27m\u001b[K"]
