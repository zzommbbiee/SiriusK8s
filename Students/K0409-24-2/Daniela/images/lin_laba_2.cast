[353.544478, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 349 (press h for help or q to quit)\u001b[27m\u001b[K"]
[353.580964, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               For example, for WPA Wi-Fi with PSK, the line would be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 350 (press h for help or q to quit)\u001b[27m\u001b[K"]
[353.584543, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 351 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                   802-11-wireless-security.psk:secret12345\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 352 (press h for help or q to quit)\u001b[27m\u001b[K"]
[353.650029, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 353 (press h for help or q to quit)\u001b[27m\u001b[K"]
[353.650442, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               For 802.1X password, the line would be\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 354 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
