[337.103618, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[337.10484, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 122 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       Use this command to show NetworkManager status and permissions. You can also\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 123 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       get and change system hostname, as well as NetworkManager logging level and\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 124 (press h for help or q to quit)\u001b[27m\u001b[K"]
[339.288721, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K       domains.\u001b[m"]
