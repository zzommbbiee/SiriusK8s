[352.417457, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[352.417489, "o", "               the \u001b[4mID\u001b[24m denotes a D-Bus active connection path in the format of\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 300 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.417506, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[352.417538, "o", "               /org/freedesktop/NetworkManager/ActiveConnection/\u001b[4mnum\u001b[24m or just \u001b[4mnum\u001b[24m.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 301 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.428561, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m"]
[352.429191, "o", "\r\n\u001b[7m Manual page nmcli(1) line 302 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           It is possible to filter the output using the global \u001b[1m--fields \u001b[22moption. Use\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 303 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           the following values:\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 304 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.440362, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 305 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.440629, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[352.440663, "o", "           \u001b[1mprofile\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 306 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               only shows static profile configuration.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 307 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.449046, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[352.449289, "o", "\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 308 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           \u001b[1mactive\u001b[0m\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 309 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K               only shows active connection data (when the profile is active).\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 310 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.458457, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[352.45866, "o", "\u001b[m"]
[352.458687, "o", "\r\n\u001b[7m Manual page nmcli(1) line 311 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           You can also specify particular fields. For static configuration, use\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 312 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           setting and property names as described in \u001b[1mnm-settings-nmcli\u001b[22m(5) manual\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 313 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.478252, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K           page. For active data use GENERAL, IP4, DHCP4, IP6, DHCP6, VPN.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 314 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.478801, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 315 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[352.478853, "o", "           When no command is given to the \u001b[1mnmcli connection\u001b[22m, the default action is\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 316 (press h for help or q to quit)\u001b[27m\u001b[K"]
[352.498809, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[352.499367, "o", "           \u001b[1mnmcli connection show\u001b[22m.\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 317 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K"]
[352.499602, "o", "\u001b[m"]
