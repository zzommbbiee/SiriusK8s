[348.900322, "o", "       \u001b[1mnmcli connection \u001b[22m{\u001b[1mshow \u001b[22m| \u001b[1mup \u001b[22m| \u001b[1mdown \u001b[22m| \u001b[1mmodify \u001b[22m| \u001b[1madd \u001b[22m| \u001b[1medit \u001b[22m| \u001b[1mclone \u001b[22m| \u001b[1mdelete \u001b[22m|\u001b[m"]
[348.900363, "o", "\r\n\u001b[7m Manual page nmcli(1) line 243 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KB\bB\r\u001b[K                        \u001b[1mmonitor \u001b[22m| \u001b[1mreload \u001b[22m| \u001b[1mload \u001b[22m| \u001b[1mimport \u001b[22m| \u001b[1mexport \u001b[22m| \u001b[1mmigrate\u001b[22m}\u001b[m\r\n\u001b[7m Manual page nmcli(1) line 244 (press h for help or q to quit)\u001b[27m\u001b[K"]
