[359.363523, "o", "\u001b[H\u001bM           completion in shell.\u001b[m"]
[359.363731, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 54 (press h for help or q to quit)\u001b[27m\u001b[K"]
[359.363758, "o", "\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K\u001b[H\u001bM           completions for the last argument. This is useful to implement argument\u001b[m"]
