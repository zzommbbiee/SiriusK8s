[354.600158, "o", "\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 262 (press h for help or q to quit)\u001b[27m\u001b[K\r\u001b[K \u001b[KESC\b\b\bESC\u001b[KO\bO\u001b[KA\bA\r\u001b[K"]
[354.600191, "o", "\u001b[H\u001bM       See also \u001b[1mnmcli connection monitor \u001b[22mand \u001b[1mnmcli device monitor \u001b[22mto watch for\u001b[m\r\n\u001b[24;1H\r\u001b[K\u001b[7m Manual page nmcli(1) line 261 (press h for help or q to quit)\u001b[27m\u001b[K"]
