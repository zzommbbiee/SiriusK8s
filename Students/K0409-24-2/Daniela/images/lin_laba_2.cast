[535.921518, "o", "IP-ROUTE(8)                             Linux                             IP-ROUTE(8)\u001b[m\r\n\u001b[m\r\n\u001b[1mNAME\u001b[0m\u001b[m\r\n       ip-route - routing table management\u001b[m\r\n\u001b[m\r\n\u001b[1mSYNOPSIS\u001b[0m\u001b[m\r\n       \u001b[1mip \u001b[22m[ \u001b[4mip-OPTIONS\u001b[24m ] \u001b[1mroute  \u001b[22m{ \u001b[4mCOMMAND\u001b[24m | \u001b[1mhelp \u001b[22m}\u001b[m\r\n\u001b[m\r\n       \u001b[1mip route \u001b[22m{ \u001b[1mshow \u001b[22m| \u001b[1mflush \u001b[22m} \u001b[4mSELECTOR\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1mip route save \u001b[4m\u001b[22mSELECTOR\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1mip route restore\u001b[0m\u001b[m\r\n\u001b[m\r\n       \u001b[1mip route get \u001b[4m\u001b[22mROUTE_GET_FLAGS\u001b[24m \u001b[4mADDRESS\u001b[24m [ \u001b[1mfrom \u001b[4m\u001b[22mADDRESS\u001b[24m \u001b[1miif \u001b[4m\u001b[22mSTRING\u001b[24m  ] [ \u001b[1moif \u001b[4m\u001b[22mSTRING\u001b[0m\u001b[m\r\n               ] [ \u001b[1mmark \u001b[4m\u001b[22mMARK\u001b[24m ] [ \u001b[1mtos \u001b[4m\u001b[22mTOS\u001b[24m ] [ \u001b[1mvrf \u001b[4m\u001b[22mNAME\u001b[24m ] [ \u001b[1mipproto \u001b[4m\u001b[22mPROTOCOL\u001b[24m ] [ \u001b[1msport\u001b[0m\u001b[m\r\n               \u001b[4mNUMBER\u001b[24m ] [ \u001b[1mdport \u001b[4m\u001b[22mNUMBER\u001b[24m ]\u001b[m\r\n\u001b[m\r\n       \u001b[1mip route \u001b[22m{ \u001b[1madd \u001b[22m| \u001b[1mdel \u001b[22m| \u001b[1mchange \u001b[22m| \u001b[1mappend \u001b[22m| \u001b[1mreplace \u001b[22m} \u001b[4mROUTE\u001b[0m\u001b[m\r\n\u001b[m\r\n"]
